{% if streaming %}
  # ========== Streaming Parser ==========
  # Line-oriented streaming for chunk-by-chunk processing.

  # Stream events with owned content (safe across chunk boundaries).
  module StreamEvent
{% for type in types %}
{% if type.kind == "bracket" %}
    {{ type.name }}Start = Data.define(:span)
    {{ type.name }}End = Data.define(:span)
{% elsif type.kind == "content" %}
    {{ type.name }} = Data.define(:content, :span)
{% endif %}
{% endfor %}
    Error = Data.define(:code, :span)
  end

  # Streaming parser for chunk-by-chunk input.
  class StreamingParser
    DEFAULT_MAX_BUFFER = 4096

    def initialize(max_buffer: DEFAULT_MAX_BUFFER)
      @buffer = +''
      @max_buffer = max_buffer
      @global_offset = 0
      @line = 1
      @column = 1
    end

    # Parse a chunk, yielding events for complete lines.
    # Returns :need_more_data or :complete
    def parse(chunk, &on_event)
      @buffer << chunk.b

      return :need_more_data if @buffer.empty?

      if @buffer.bytesize > @max_buffer
        yield StreamEvent::Error.new(:buffer_overflow, @global_offset..@global_offset)
        @buffer.clear
        return :complete
      end

      # Find last complete line
      last_newline = @buffer.rindex(10.chr(Encoding::BINARY))
      return :need_more_data unless last_newline

      # Extract and parse complete lines
      to_parse = @buffer.slice!(0, last_newline + 1)
      offset = @global_offset

      parser = Parser.new(to_parse)
      parser.instance_variable_set(:@line, @line)
      parser.instance_variable_set(:@column, @column)

      parser.parse do |event|
        yield to_stream_event(event, offset)
      end

      # Update state
      @global_offset += to_parse.bytesize
      to_parse.each_byte do |b|
        if b == 10
          @line += 1
          @column = 1
        else
          @column += 1
        end
      end

      :need_more_data
    end

    # Finish parsing - handle remaining buffer
    def finish(&on_event)
      return if @buffer.empty?

      parser = Parser.new(@buffer)
      parser.instance_variable_set(:@line, @line)
      parser.instance_variable_set(:@column, @column)

      parser.parse do |event|
        yield to_stream_event(event, @global_offset)
      end

      @buffer.clear
    end

    # Current global byte offset
    attr_reader :global_offset

    # Current line number
    attr_reader :line

    # Current column number
    attr_reader :column

    private

    def to_stream_event(event, offset)
      case event
{% for type in types %}
{% if type.kind == "bracket" %}
      when Event::{{ type.name }}Start
        StreamEvent::{{ type.name }}Start.new(adjust_span(event.span, offset))
      when Event::{{ type.name }}End
        StreamEvent::{{ type.name }}End.new(adjust_span(event.span, offset))
{% elsif type.kind == "content" %}
      when Event::{{ type.name }}
        StreamEvent::{{ type.name }}.new(event.content.dup, adjust_span(event.span, offset))
{% endif %}
{% endfor %}
      when Event::Error
        StreamEvent::Error.new(event.code, adjust_span(event.span, offset))
      else
        event
      end
    end

    def adjust_span(s, offset)
      Span.new(s.start + offset, s.finish + offset)
    end
  end
{% endif %}
