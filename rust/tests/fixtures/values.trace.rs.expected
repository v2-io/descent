    #[inline(always)]
    fn char_count(bytes: &[u8]) -> u32 {
        bytes.iter().filter(|&&b| b & 0xC0 != 0x80).count() as u32
    }

    /// Scan forward to find first occurrence of b1.
    #[inline(always)]
    fn scan_to1(&mut self, b1: u8) -> Option<u8> {
