                    on_event(Event::Error { code: ParseErrorCode::ExpectedColon, span: self.span() });
                    on_event(Event::ObjectEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Comma => {
                    if self.eof() {
                        eprintln!("TRACE: L49 object:comma EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ObjectEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b',') => {
                            eprintln!("TRACE: L50 object:comma.comma | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Main;
                    continue;
                        }
                        Some(b'}') => {
                            eprintln!("TRACE: L51 object:comma.close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::ObjectEnd { span: self.span() });
                    return;
                        }
