            match state {
                State::Main => {
                    if self.eof() {
                        eprintln!("TRACE: L38 object:main EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ObjectEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L39 object:main.close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::ObjectEnd { span: self.span() });
                    return;
                        }
                        Some(b'"') => {
                            eprintln!("TRACE: L40 object:main.key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_string(on_event);
                    state = State::Colon;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L41 object:main.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
