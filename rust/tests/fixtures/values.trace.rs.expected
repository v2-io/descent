    /// Parse array -> Array
    fn parse_array<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L56 ENTER array | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::ArrayStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Main, Comma,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    eprintln!("TRACE: L58 array:main.close UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::ArrayEnd { span: self.span() });
                    return;
                }
                State::Comma => {
                    if self.eof() {
                        eprintln!("TRACE: L62 array:comma EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ArrayEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b',') => {
                            eprintln!("TRACE: L63 array:comma.comma | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L64 array:comma.close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::ArrayEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L65 array:comma.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L66 array:comma.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::ExpectedComma, span: self.span() });
                    on_event(Event::ArrayEnd { span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse string -> String
    fn parse_string<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L69 ENTER string | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'\n', b'"', b'\\') {
                Some(b'"') => {
                    eprintln!("TRACE: L71 string:main.close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::String { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\\') => {
                    eprintln!("TRACE: L72 string:main.esc | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.advance();
                    continue;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L70 string:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::UnclosedString, span: self.span() });
                    on_event(Event::String { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse number -> Number
    fn parse_number<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L78 ENTER number | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Int, Frac, Exp, ExpDigits,  }
        let mut state = State::Int;
        loop {
            match state {
                State::Int => {
                    if self.eof() {
                        eprintln!("TRACE: L79 number:int EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Integer { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'0' | b'1' | b'2' | b'3' | b'4' | b'5' | b'6' | b'7' | b'8' | b'9') => {
                            eprintln!("TRACE: L80 number:int.digit | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'.') => {
                            eprintln!("TRACE: L81 number:int.dot | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Frac;
                    continue;
                        }
                        Some(b'e' | b'E') => {
                            eprintln!("TRACE: L82 number:int.exp | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Exp;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L84 number:int.done | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Integer { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::Frac => {
                    if self.eof() {
                        eprintln!("TRACE: L87 number:frac EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Float { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'0' | b'1' | b'2' | b'3' | b'4' | b'5' | b'6' | b'7' | b'8' | b'9') => {
                            eprintln!("TRACE: L88 number:frac.digit | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'e' | b'E') => {
                            eprintln!("TRACE: L89 number:frac.exp | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Exp;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L90 number:frac.done | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Float { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::Exp => {
                    if self.eof() {
                        eprintln!("TRACE: L93 number:exp EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Number { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'+' | b'-') => {
                            eprintln!("TRACE: L94 number:exp.sign | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ExpDigits;
                    continue;
                        }
                        Some(b'0' | b'1' | b'2' | b'3' | b'4' | b'5' | b'6' | b'7' | b'8' | b'9') => {
                            eprintln!("TRACE: L95 number:exp.digit | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ExpDigits;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L96 number:exp.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidNumber, span: self.span() });
                    on_event(Event::Number { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::ExpDigits => {
                    if self.eof() {
                        eprintln!("TRACE: L98 number:exp_digits EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Float { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'0' | b'1' | b'2' | b'3' | b'4' | b'5' | b'6' | b'7' | b'8' | b'9') => {
                            eprintln!("TRACE: L99 number:exp_digits.digit | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L100 number:exp_digits.done | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Float { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse null -> Null
    fn parse_null<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L104 ENTER null | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, L1, L2,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        eprintln!("TRACE: L105 null:main EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Null { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'u') => {
                            eprintln!("TRACE: L106 null:main.u | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::L1;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L107 null:main.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidNull, span: self.span() });
                    on_event(Event::Null { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::L1 => {
                    if self.eof() {
                        eprintln!("TRACE: L108 null:l1 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Null { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L109 null:l1.l | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::L2;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L110 null:l1.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidNull, span: self.span() });
                    on_event(Event::Null { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::L2 => {
                    if self.eof() {
                        eprintln!("TRACE: L111 null:l2 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Null { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L112 null:l2.l | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::Null { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L113 null:l2.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidNull, span: self.span() });
                    on_event(Event::Null { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse true -> BoolTrue
    fn parse_true<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L116 ENTER true | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, U, E,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        eprintln!("TRACE: L117 true:main EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BoolTrue { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b']') => {
                            eprintln!("TRACE: L118 true:main.r | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::U;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L119 true:main.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidBool, span: self.span() });
                    on_event(Event::BoolTrue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::U => {
                    if self.eof() {
                        eprintln!("TRACE: L120 true:u EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BoolTrue { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'u') => {
                            eprintln!("TRACE: L121 true:u.u | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::E;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L122 true:u.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidBool, span: self.span() });
                    on_event(Event::BoolTrue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::E => {
                    if self.eof() {
                        eprintln!("TRACE: L123 true:e EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BoolTrue { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'e') => {
                            eprintln!("TRACE: L124 true:e.e | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::BoolTrue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L125 true:e.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidBool, span: self.span() });
                    on_event(Event::BoolTrue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse false -> BoolFalse
    fn parse_false<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L128 ENTER false | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, L, S, E,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        eprintln!("TRACE: L129 false:main EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'a') => {
                            eprintln!("TRACE: L130 false:main.a | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::L;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L131 false:main.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidBool, span: self.span() });
                    on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::L => {
                    if self.eof() {
                        eprintln!("TRACE: L132 false:l EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L133 false:l.l | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::S;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L134 false:l.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidBool, span: self.span() });
                    on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::S => {
                    if self.eof() {
                        eprintln!("TRACE: L135 false:s EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b's') => {
                            eprintln!("TRACE: L136 false:s.s | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::E;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L137 false:s.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidBool, span: self.span() });
                    on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::E => {
                    if self.eof() {
                        eprintln!("TRACE: L138 false:e EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'e') => {
                            eprintln!("TRACE: L139 false:e.e | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L140 false:e.err | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::InvalidBool, span: self.span() });
                    on_event(Event::BoolFalse { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
            }
        }
    }
}

// ============================================================================
// Streaming Parser (multi-chunk support)
// ============================================================================
/// Result of parsing a chunk in streaming mode.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParseResult {
    /// Parsing completed successfully (EOF reached).
    Complete,
    /// More data needed - provide another chunk.
    NeedMoreData,
}

/// Event with owned content for streaming across chunk boundaries.
#[derive(Debug, Clone, PartialEq)]
pub enum StreamEvent {
    ObjectStart { span: Range<usize> },
    ObjectEnd { span: Range<usize> },
    ArrayStart { span: Range<usize> },
    ArrayEnd { span: Range<usize> },
    String { content: Vec<u8>, span: Range<usize> },
    Number { content: Vec<u8>, span: Range<usize> },
    Integer { content: Vec<u8>, span: Range<usize> },
    Float { content: Vec<u8>, span: Range<usize> },
    Null { content: Vec<u8>, span: Range<usize> },
    BoolTrue { content: Vec<u8>, span: Range<usize> },
    BoolFalse { content: Vec<u8>, span: Range<usize> },
    Error { code: ParseErrorCode, span: Range<usize> },
}
impl StreamEvent {
    /// Convert from borrowed Event to owned StreamEvent.
    fn from_event(event: Event<'_>, offset: usize) -> Self {
        match event {
            Event::ObjectStart { span } => {
                StreamEvent::ObjectStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ObjectEnd { span } => {
                StreamEvent::ObjectEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ArrayStart { span } => {
                StreamEvent::ArrayStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ArrayEnd { span } => {
                StreamEvent::ArrayEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::String { content, span } => {
                StreamEvent::String {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Number { content, span } => {
                StreamEvent::Number {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Integer { content, span } => {
                StreamEvent::Integer {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Float { content, span } => {
                StreamEvent::Float {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Null { content, span } => {
                StreamEvent::Null {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::BoolTrue { content, span } => {
                StreamEvent::BoolTrue {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::BoolFalse { content, span } => {
                StreamEvent::BoolFalse {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Error { code, span } => {
                StreamEvent::Error { code, span: (span.start + offset)..(span.end + offset) }
            }
        }
    }
}

/// Streaming parser for chunk-by-chunk input.
///
/// Wraps the single-buffer `Parser` to handle input arriving in chunks.
/// Buffers incomplete content across chunk boundaries.
///
/// # Example
///
/// ```text
/// let mut parser = StreamingParser::new();
/// loop {
///     match parser.parse(chunk, |event| handle(event)) {
///         ParseResult::Complete => break,
///         ParseResult::NeedMoreData => {
///             chunk = get_next_chunk();
///             if chunk.is_empty() {
///                 parser.finish(|event| handle(event));
///                 break;
///             }

///         }

///     }

/// }

/// ```

pub struct StreamingParser {
    /// Buffer for incomplete content at chunk boundaries.
    buffer: Vec<u8>,
    /// Maximum buffer size before error (default 4KB).
    max_buffer: usize,
    /// Global byte offset for span calculation.
    global_offset: usize,
    /// Line number (persists across chunks).
    line: u32,
    /// Column number (persists across chunks).
    column: u32,
}
impl Default for StreamingParser {
    fn default() -> Self {
        Self::new()
    }
}
impl StreamingParser {
    /// Create a new streaming parser with default settings.
    pub fn new() -> Self {
        Self::with_max_buffer(4096)
    }

    /// Create a streaming parser with custom buffer limit.
    pub fn with_max_buffer(max_buffer: usize) -> Self {
        Self {
            buffer: Vec::new(),
            max_buffer,
            global_offset: 0,
            line: 1,
            column: 1,
        }
    }

    /// Parse a chunk of input, emitting events for complete lines.
    ///
    /// Uses line-oriented streaming: only parses complete lines (ending in `\n`).
    /// Incomplete lines are buffered until more data arrives.
    ///
    /// Returns `NeedMoreData` if the chunk ends mid-line.
    /// Call `finish()` after the last chunk to handle any remaining content.
    pub fn parse<F>(&mut self, chunk: &[u8], mut on_event: F) -> ParseResult
    where
        F: FnMut(StreamEvent),
    {
        // Append new chunk to buffer
        self.buffer.extend_from_slice(chunk);
        if self.buffer.is_empty() {
            return ParseResult::NeedMoreData;
        }

        // Check buffer size limit
        if self.buffer.len() > self.max_buffer {
            on_event(StreamEvent::Error {
                code: ParseErrorCode::UnexpectedEof, // Buffer overflow
                span: self.global_offset..self.global_offset,
            });
            self.buffer.clear();
            return ParseResult::Complete;
        }

        // Find last complete line (ending with \n)
        let last_newline = self.buffer.iter().rposition(|&b| b == b'\n');
        let parse_end = match last_newline {
            Some(pos) => pos + 1, // Include the newline
            None => return ParseResult::NeedMoreData, // No complete line yet
        };
        // Extract complete lines to parse
        let to_parse: Vec<u8> = self.buffer.drain(..parse_end).collect();
        let offset = self.global_offset;
        // Parse complete lines
        let mut inner = Parser::new(&to_parse);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
        // Update state
        self.global_offset += to_parse.len();
        for &b in &to_parse {
            if b == b'\n' {
                self.line += 1;
                self.column = 1;
            } else if b & 0xC0 != 0x80 {
                // Columns are char-based: skip UTF-8 continuation bytes.
                self.column += 1;
            }
        }
        ParseResult::NeedMoreData
    }

    /// Signal end of input and handle any remaining buffered content.
    ///
    /// This triggers EOF handling for any incomplete constructs.
    pub fn finish<F>(mut self, mut on_event: F)
    where
        F: FnMut(StreamEvent),
    {
        if self.buffer.is_empty() {
            return;
        }

        // Parse remaining buffer - this will hit EOF
        let input = std::mem::take(&mut self.buffer);
        let offset = self.global_offset;
        let mut inner = Parser::new(&input);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
    }

    /// Returns the current global byte offset.
    pub fn offset(&self) -> usize {
        self.global_offset
    }

    /// Returns the current line number.
    pub fn line(&self) -> u32 {
        self.line
    }

    /// Returns the current column number.
    pub fn column(&self) -> u32 {
        self.column
    }
}

