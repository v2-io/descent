                    on_event(Event::Error { code: ParseErrorCode::UnexpectedChar, span: self.span() });
                    on_event(Event::ObjectEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Colon => {
                    if self.eof() {
                        eprintln!("TRACE: L44 object:colon EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ObjectEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b':') => {
                            eprintln!("TRACE: L45 object:colon.colon | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_document(on_event);
                    state = State::Comma;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L46 object:colon.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
