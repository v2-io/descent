    // ========== Generated Parse Functions ==========
    /// Parse document
    fn parse_document<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        #[derive(Clone, Copy)]
        enum State { Main, Indented,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    state = State::Indented;
                    continue;
                        }
                        Some(b'#') => {
                    self.parse_heading(on_event);
                    continue;
                        }
                        Some(b'`') => {
                    self.parse_maybe_fence(on_event);
                    continue;
                        }
                        Some(b'>') => {
                    self.advance();
                    self.parse_blockquote(on_event);
                    continue;
                        }
                        Some(b'-') => {
                    self.advance();
                    self.parse_dash_line(on_event);
                    continue;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    continue;
                        }
                    }
                }
                State::Indented => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                    self.advance();
                    continue;
                        }
                        Some(b'-') => {
                    self.advance();
                    self.parse_list_item(self.col(), on_event);
                    continue;
                        }
                        Some(b'*') => {
                    self.advance();
                    self.parse_list_item(self.col(), on_event);
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse heading -> Heading
    fn parse_heading<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::HeadingStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Hashes, Content, Trailing, CloseHash,  }
        let mut state = State::Hashes;
        loop {
            match state {
                State::Hashes => {
                    if self.eof() {
                        on_event(Event::HeadingEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'#') => {
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Content => {
                    if self.eof() {
                        on_event(Event::HeadingEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    state = State::Trailing;
                    continue;
                        }
                    }
                }
                State::Trailing => {
                    if self.eof() {
                        on_event(Event::HeadingEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                        Some(b'#') => {
                    self.advance();
                    state = State::CloseHash;
                    continue;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    continue;
                        }
                    }
                }
                State::CloseHash => {
                    if self.eof() {
                        on_event(Event::HeadingEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'#') => {
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    state = State::Trailing;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse paragraph -> Paragraph
    fn parse_paragraph<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::ParagraphStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Main, Check,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        on_event(Event::ParagraphEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    self.advance();
                    state = State::Check;
                    continue;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    continue;
                        }
                    }
                }
                State::Check => {
                    if self.eof() {
                        on_event(Event::ParagraphEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'#') => {
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'`') => {
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'>') => {
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'-') => {
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'*') => {
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse maybe_fence
    fn parse_maybe_fence<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        #[derive(Clone, Copy)]
        enum State { Check1, Check2,  }
        let mut state = State::Check1;
        loop {
            match state {
                State::Check1 => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    state = State::Check2;
                    continue;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::Check2 => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    self.parse_code_block(on_event);
                    return;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse code_block -> CodeBlock
    fn parse_code_block<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::CodeBlockStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Info, Content, End1, End2, End3,  }
        let mut state = State::Info;
        loop {
            match state {
                State::Info => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        None => {
                            on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Content => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    state = State::End1;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    continue;
                        }
                        _ => {
                    self.parse_code_line(on_event);
                    continue;
                        }
                    }
                }
                State::End1 => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    state = State::End2;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_code_line(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::End2 => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    state = State::End3;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_code_line(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::End3 => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::CodeBlockEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    continue;
                        }
                        _ => {
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse code_line -> Code
    fn parse_code_line<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        self.mark();
        loop {
            match self.scan_to1(b'\n') {
                Some(b'\n') => {
                    self.advance();
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedCode, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse blockquote -> Blockquote
    fn parse_blockquote<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::BlockquoteStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Start, Content, After, Next, Lazy,  }
        let mut state = State::Start;
        loop {
            match state {
                State::Start => {
                    if self.eof() {
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ') => {
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        Some(b'>') => {
                    self.advance();
                    self.parse_blockquote(on_event);
                    state = State::After;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::Content => {
                    if self.eof() {
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    continue;
                        }
                    }
                }
                State::After => {
                    if self.eof() {
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    state = State::After;
                    continue;
                        }
                    }
                }
                State::Next => {
                    if self.eof() {
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'>') => {
                    self.advance();
                    state = State::Start;
                    continue;
                        }
                        Some(b'\n') => {
                    on_event(Event::BlockquoteEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    state = State::Lazy;
                    continue;
                        }
                        _ => {
                    on_event(Event::BlockquoteEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Lazy => {
                    if self.eof() {
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'>') => {
                    self.advance();
                    state = State::Start;
                    continue;
                        }
                        Some(b'\n') => {
                    on_event(Event::BlockquoteEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse dash_line
    fn parse_dash_line<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        #[derive(Clone, Copy)]
        enum State { First, Second, HrCheck,  }
        let mut state = State::First;
        loop {
            match state {
                State::First => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'-') => {
                    self.advance();
                    state = State::Second;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        Some(b'\n') => {
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::Second => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'-') => {
                    self.advance();
                    state = State::HrCheck;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.parse_paragraph(on_event);
                    return;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::HrCheck => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'-') => {
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    self.parse_thematic_break(on_event);
                    return;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse star_line
    fn parse_star_line<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        #[derive(Clone, Copy)]
        enum State { First, Second, HrCheck,  }
        let mut state = State::First;
        loop {
            match state {
                State::First => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                    self.advance();
                    state = State::Second;
                    continue;
                        }
                        _ => {
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::Second => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                    self.advance();
                    state = State::HrCheck;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        Some(b'\n') => {
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        _ => {
                    self.prepend_bytes(b"*");
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::HrCheck => {
                    if self.eof() {
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    self.parse_thematic_break(on_event);
                    return;
                        }
                        _ => {
                    self.prepend_bytes(b"**");
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse thematic_break -> ThematicBreak
    fn parse_thematic_break<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::ThematicBreakStart { span: start_span.clone() });
        loop {
            if self.eof() {
                on_event(Event::ThematicBreakEnd { span: self.span() });
                return;
            }
                    on_event(Event::ThematicBreakEnd { span: self.span() });
                    return;
        }
    }

    /// Parse list_item -> ListItem
    fn parse_list_item<F>(&mut self, col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::ListItemStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, Next, AfterBlank, CheckIndent,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                    self.parse_inline(on_event);
                    continue;
                        }
                    }
                }
                State::Next => {
                    if self.eof() {
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    self.advance();
                    state = State::AfterBlank;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    state = State::CheckIndent;
                    continue;
                        }
                        Some(b'-') => {
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        Some(b'*') => {
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::AfterBlank => {
                    if self.eof() {
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                    self.advance();
                    state = State::CheckIndent;
                    continue;
                        }
                        _ => {
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::CheckIndent => {
                    if self.eof() {
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                    self.advance();
                    continue;
                        }
                        _ if self.col() <= col => {
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        Some(b'-') => {
                    self.advance();
                    self.parse_list_item(self.col(), on_event);
                    state = State::Next;
                    continue;
                        }
                        Some(b'*') => {
                    self.advance();
                    self.parse_list_item(self.col(), on_event);
                    state = State::Next;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    state = State::AfterBlank;
                    continue;
                        }
                        _ => {
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse inline
    fn parse_inline<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        #[derive(Clone, Copy)]
        enum State { Main, AfterStar, AfterTwoStars, AfterUnder, AfterTwoUnders, AfterTilde, AfterTwoTildes,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'*') => {
                    self.advance();
                    state = State::AfterStar;
                    continue;
                        }
                        Some(b'_') => {
                    self.advance();
                    state = State::AfterUnder;
                    continue;
                        }
                        Some(b'~') => {
                    self.advance();
                    state = State::AfterTilde;
                    continue;
                        }
                        Some(b'\n') => {
                    return;
                        }
                        _ => {
                    self.parse_text(on_event);
                    continue;
                        }
                    }
                }
                State::AfterStar => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                    self.advance();
                    state = State::AfterTwoStars;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTwoStars => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"**"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                    self.parse_strong(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterUnder => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'_') => {
                    self.advance();
                    state = State::AfterTwoUnders;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"_"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis_under(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTwoUnders => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"__"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                    self.parse_strong_under(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTilde => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'~') => {
                    self.advance();
                    state = State::AfterTwoTildes;
                    continue;
                        }
                        _ => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTwoTildes => {
                    if self.eof() {
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~~"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                    self.parse_strikethrough(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse code_span -> Code
    fn parse_code_span<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        self.mark();
        loop {
            match self.scan_to2(b'`', b'\n') {
                Some(b'`') => {
                    self.set_term(0);
                    self.advance();
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse emphasis -> Emphasis
    fn parse_emphasis<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::EmphasisStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckStar, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'*') => {
                    state = State::CheckStar;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_emph_text(on_event);
                    continue;
                        }
                    }
                }
                State::CheckStar => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'*') => {
                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                    self.advance();
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RightFlankDouble => {
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                }
                State::NotRightFlanking => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                    self.advance();
                    state = State::NotRfDouble;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::NotRfDouble => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"**"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_strong(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse strong -> Strong
    fn parse_strong<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::StrongStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckStar, RightFlankSingle, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'*') => {
                    state = State::CheckStar;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::StrongEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_emph_text(on_event);
                    continue;
                        }
                    }
                }
                State::CheckStar => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'*') => {
                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                    self.advance();
                    state = State::RightFlankSingle;
                    continue;
                        }
                    }
                }
                State::RightFlankSingle => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::RightFlankDouble => {
                    self.advance();
                    on_event(Event::StrongEnd { span: self.span() });
                    return;
                }
                State::NotRightFlanking => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                    self.advance();
                    state = State::NotRfDouble;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::NotRfDouble => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"**"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_strong(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse emphasis_under -> Emphasis
    fn parse_emphasis_under<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::EmphasisStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckUnder, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'_') => {
                    state = State::CheckUnder;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_emph_text_under(on_event);
                    continue;
                        }
                    }
                }
                State::CheckUnder => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'_') => {
                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                    self.advance();
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RightFlankDouble => {
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                }
                State::NotRightFlanking => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'_') => {
                    self.advance();
                    state = State::NotRfDouble;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"_"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis_under(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::NotRfDouble => {
                    if self.eof() {
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"__"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_strong_under(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse strong_under -> Strong
    fn parse_strong_under<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::StrongStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckUnder, RightFlankSingle, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'_') => {
                    state = State::CheckUnder;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::StrongEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_emph_text_under(on_event);
                    continue;
                        }
                    }
                }
                State::CheckUnder => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'_') => {
                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                    self.advance();
                    state = State::RightFlankSingle;
                    continue;
                        }
                    }
                }
                State::RightFlankSingle => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"_"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis_under(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::RightFlankDouble => {
                    self.advance();
                    on_event(Event::StrongEnd { span: self.span() });
                    return;
                }
                State::NotRightFlanking => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'_') => {
                    self.advance();
                    state = State::NotRfDouble;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"_"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_emphasis_under(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::NotRfDouble => {
                    if self.eof() {
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"__"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_strong_under(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse strikethrough -> Strikethrough
    fn parse_strikethrough<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        let start_span = self.span();
        on_event(Event::StrikethroughStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckTilde, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'~') => {
                    state = State::CheckTilde;
                    continue;
                        }
                        Some(b'\n') => {
                    self.advance();
                    on_event(Event::StrikethroughEnd { span: self.span() });
                    return;
                        }
                        _ => {
                    self.parse_strike_text(on_event);
                    continue;
                        }
                    }
                }
                State::CheckTilde => {
                    if self.eof() {
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'~') => {
                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::RightFlankDouble => {
                    self.advance();
                    on_event(Event::StrikethroughEnd { span: self.span() });
                    return;
                }
                State::NotRightFlanking => {
                    if self.eof() {
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'~') => {
                    self.advance();
                    state = State::NotRfDouble;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_strikethrough(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::NotRfDouble => {
                    if self.eof() {
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~~"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                    self.parse_strikethrough(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse text -> Text
    fn parse_text<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        self.mark();
        loop {
            match self.scan_to5(b'`', b'*', b'_', b'~', b'\n') {
                Some(b'`') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'*') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'_') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'~') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse emph_text -> Text
    fn parse_emph_text<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        self.mark();
        loop {
            match self.scan_to3(b'`', b'*', b'\n') {
                Some(b'`') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'*') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse emph_text_under -> Text
    fn parse_emph_text_under<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        self.mark();
        loop {
            match self.scan_to3(b'`', b'_', b'\n') {
                Some(b'`') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'_') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse strike_text -> Text
    fn parse_strike_text<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        self.mark();
        loop {
            match self.scan_to3(b'`', b'~', b'\n') {
                Some(b'`') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'~') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }
}

// ============================================================================
// Streaming Parser (multi-chunk support)
// ============================================================================
/// Result of parsing a chunk in streaming mode.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParseResult {
    /// Parsing completed successfully (EOF reached).
    Complete,
    /// More data needed - provide another chunk.
    NeedMoreData,
}

/// Event with owned content for streaming across chunk boundaries.
#[derive(Debug, Clone, PartialEq)]
pub enum StreamEvent {
    HeadingStart { span: Range<usize> },
    HeadingEnd { span: Range<usize> },
    ParagraphStart { span: Range<usize> },
    ParagraphEnd { span: Range<usize> },
    CodeBlockStart { span: Range<usize> },
    CodeBlockEnd { span: Range<usize> },
    BlockquoteStart { span: Range<usize> },
    BlockquoteEnd { span: Range<usize> },
    ListItemStart { span: Range<usize> },
    ListItemEnd { span: Range<usize> },
    ThematicBreakStart { span: Range<usize> },
    ThematicBreakEnd { span: Range<usize> },
    EmphasisStart { span: Range<usize> },
    EmphasisEnd { span: Range<usize> },
    StrongStart { span: Range<usize> },
    StrongEnd { span: Range<usize> },
    StrikethroughStart { span: Range<usize> },
    StrikethroughEnd { span: Range<usize> },
    Text { content: Vec<u8>, span: Range<usize> },
    Code { content: Vec<u8>, span: Range<usize> },
    Error { code: ParseErrorCode, span: Range<usize> },
}
impl StreamEvent {
    /// Convert from borrowed Event to owned StreamEvent.
    fn from_event(event: Event<'_>, offset: usize) -> Self {
        match event {
            Event::HeadingStart { span } => {
                StreamEvent::HeadingStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::HeadingEnd { span } => {
                StreamEvent::HeadingEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ParagraphStart { span } => {
                StreamEvent::ParagraphStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ParagraphEnd { span } => {
                StreamEvent::ParagraphEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::CodeBlockStart { span } => {
                StreamEvent::CodeBlockStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::CodeBlockEnd { span } => {
                StreamEvent::CodeBlockEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::BlockquoteStart { span } => {
                StreamEvent::BlockquoteStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::BlockquoteEnd { span } => {
                StreamEvent::BlockquoteEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ListItemStart { span } => {
                StreamEvent::ListItemStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ListItemEnd { span } => {
                StreamEvent::ListItemEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ThematicBreakStart { span } => {
                StreamEvent::ThematicBreakStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ThematicBreakEnd { span } => {
                StreamEvent::ThematicBreakEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::EmphasisStart { span } => {
                StreamEvent::EmphasisStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::EmphasisEnd { span } => {
                StreamEvent::EmphasisEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrongStart { span } => {
                StreamEvent::StrongStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrongEnd { span } => {
                StreamEvent::StrongEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrikethroughStart { span } => {
                StreamEvent::StrikethroughStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrikethroughEnd { span } => {
                StreamEvent::StrikethroughEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::Text { content, span } => {
                StreamEvent::Text {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Code { content, span } => {
                StreamEvent::Code {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Error { code, span } => {
                StreamEvent::Error { code, span: (span.start + offset)..(span.end + offset) }
            }
        }
    }
}

/// Streaming parser for chunk-by-chunk input.
///
/// Wraps the single-buffer `Parser` to handle input arriving in chunks.
/// Buffers incomplete content across chunk boundaries.
///
/// # Example
///
/// ```text
/// let mut parser = StreamingParser::new();
/// loop {
///     match parser.parse(chunk, |event| handle(event)) {
///         ParseResult::Complete => break,
///         ParseResult::NeedMoreData => {
///             chunk = get_next_chunk();
///             if chunk.is_empty() {
///                 parser.finish(|event| handle(event));
///                 break;
///             }

///         }

///     }

/// }

/// ```

pub struct StreamingParser {
    /// Buffer for incomplete content at chunk boundaries.
    buffer: Vec<u8>,
    /// Maximum buffer size before error (default 4KB).
    max_buffer: usize,
    /// Global byte offset for span calculation.
    global_offset: usize,
    /// Line number (persists across chunks).
    line: u32,
    /// Column number (persists across chunks).
    column: u32,
}
impl Default for StreamingParser {
    fn default() -> Self {
        Self::new()
    }
}
impl StreamingParser {
    /// Create a new streaming parser with default settings.
    pub fn new() -> Self {
        Self::with_max_buffer(4096)
    }

    /// Create a streaming parser with custom buffer limit.
    pub fn with_max_buffer(max_buffer: usize) -> Self {
        Self {
            buffer: Vec::new(),
            max_buffer,
            global_offset: 0,
            line: 1,
            column: 1,
        }
    }

    /// Parse a chunk of input, emitting events for complete lines.
    ///
    /// Uses line-oriented streaming: only parses complete lines (ending in `\n`).
    /// Incomplete lines are buffered until more data arrives.
    ///
    /// Returns `NeedMoreData` if the chunk ends mid-line.
    /// Call `finish()` after the last chunk to handle any remaining content.
    pub fn parse<F>(&mut self, chunk: &[u8], mut on_event: F) -> ParseResult
    where
        F: FnMut(StreamEvent),
    {
        // Append new chunk to buffer
        self.buffer.extend_from_slice(chunk);
        if self.buffer.is_empty() {
            return ParseResult::NeedMoreData;
        }

        // Check buffer size limit
        if self.buffer.len() > self.max_buffer {
            on_event(StreamEvent::Error {
                code: ParseErrorCode::UnexpectedEof, // Buffer overflow
                span: self.global_offset..self.global_offset,
            });
            self.buffer.clear();
            return ParseResult::Complete;
        }

        // Find last complete line (ending with \n)
        let last_newline = self.buffer.iter().rposition(|&b| b == b'\n');
        let parse_end = match last_newline {
            Some(pos) => pos + 1, // Include the newline
            None => return ParseResult::NeedMoreData, // No complete line yet
        };
        // Extract complete lines to parse
        let to_parse: Vec<u8> = self.buffer.drain(..parse_end).collect();
        let offset = self.global_offset;
        // Parse complete lines
        let mut inner = Parser::new(&to_parse);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
        // Update state
        self.global_offset += to_parse.len();
        for &b in &to_parse {
            if b == b'\n' {
                self.line += 1;
                self.column = 1;
            } else if b & 0xC0 != 0x80 {
                // Columns are char-based: skip UTF-8 continuation bytes.
                self.column += 1;
            }
        }
        ParseResult::NeedMoreData
    }

    /// Signal end of input and handle any remaining buffered content.
    ///
    /// This triggers EOF handling for any incomplete constructs.
    pub fn finish<F>(mut self, mut on_event: F)
    where
        F: FnMut(StreamEvent),
    {
        if self.buffer.is_empty() {
            return;
        }

        // Parse remaining buffer - this will hit EOF
        let input = std::mem::take(&mut self.buffer);
        let offset = self.global_offset;
        let mut inner = Parser::new(&input);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
    }

    /// Returns the current global byte offset.
    pub fn offset(&self) -> usize {
        self.global_offset
    }

    /// Returns the current line number.
    pub fn line(&self) -> u32 {
        self.line
    }

    /// Returns the current column number.
    pub fn column(&self) -> u32 {
        self.column
    }
}

