use std::ops::Range;
/// Events emitted by the parser.
#[derive(Debug, Clone, PartialEq)]
pub enum Event<'a> {
    HeadingStart { span: Range<usize> },
    HeadingEnd { span: Range<usize> },
    ParagraphStart { span: Range<usize> },
    ParagraphEnd { span: Range<usize> },
    CodeBlockStart { span: Range<usize> },
    CodeBlockEnd { span: Range<usize> },
    BlockquoteStart { span: Range<usize> },
    BlockquoteEnd { span: Range<usize> },
    ListItemStart { span: Range<usize> },
    ListItemEnd { span: Range<usize> },
    ThematicBreakStart { span: Range<usize> },
    ThematicBreakEnd { span: Range<usize> },
    EmphasisStart { span: Range<usize> },
    EmphasisEnd { span: Range<usize> },
    StrongStart { span: Range<usize> },
    StrongEnd { span: Range<usize> },
    StrikethroughStart { span: Range<usize> },
    StrikethroughEnd { span: Range<usize> },
    Text { content: std::borrow::Cow<'a, [u8]>, span: Range<usize> },
    Code { content: std::borrow::Cow<'a, [u8]>, span: Range<usize> },
    Error { code: ParseErrorCode, span: Range<usize> },
}
impl<'a> Event<'a> {
    /// Format event as a single line for test output.
    pub fn format_line(&self) -> String {
        match self {
            Event::HeadingStart { span } => {
                format!("HeadingStart @ {}..{}", span.start, span.end)
            }
            Event::HeadingEnd { span } => {
                format!("HeadingEnd @ {}..{}", span.start, span.end)
            }
            Event::ParagraphStart { span } => {
                format!("ParagraphStart @ {}..{}", span.start, span.end)
            }
            Event::ParagraphEnd { span } => {
                format!("ParagraphEnd @ {}..{}", span.start, span.end)
            }
            Event::CodeBlockStart { span } => {
                format!("CodeBlockStart @ {}..{}", span.start, span.end)
            }
            Event::CodeBlockEnd { span } => {
                format!("CodeBlockEnd @ {}..{}", span.start, span.end)
            }
            Event::BlockquoteStart { span } => {
                format!("BlockquoteStart @ {}..{}", span.start, span.end)
            }
            Event::BlockquoteEnd { span } => {
                format!("BlockquoteEnd @ {}..{}", span.start, span.end)
            }
            Event::ListItemStart { span } => {
                format!("ListItemStart @ {}..{}", span.start, span.end)
            }
            Event::ListItemEnd { span } => {
                format!("ListItemEnd @ {}..{}", span.start, span.end)
            }
            Event::ThematicBreakStart { span } => {
                format!("ThematicBreakStart @ {}..{}", span.start, span.end)
            }
            Event::ThematicBreakEnd { span } => {
                format!("ThematicBreakEnd @ {}..{}", span.start, span.end)
            }
            Event::EmphasisStart { span } => {
                format!("EmphasisStart @ {}..{}", span.start, span.end)
            }
            Event::EmphasisEnd { span } => {
                format!("EmphasisEnd @ {}..{}", span.start, span.end)
            }
            Event::StrongStart { span } => {
                format!("StrongStart @ {}..{}", span.start, span.end)
            }
            Event::StrongEnd { span } => {
                format!("StrongEnd @ {}..{}", span.start, span.end)
            }
            Event::StrikethroughStart { span } => {
                format!("StrikethroughStart @ {}..{}", span.start, span.end)
            }
            Event::StrikethroughEnd { span } => {
                format!("StrikethroughEnd @ {}..{}", span.start, span.end)
            }
            Event::Text { content, span } => {
                let s = std::str::from_utf8(content.as_ref()).unwrap_or("<invalid utf8>");
                format!("Text {:?} @ {}..{}", s, span.start, span.end)
            }
            Event::Code { content, span } => {
                let s = std::str::from_utf8(content.as_ref()).unwrap_or("<invalid utf8>");
                format!("Code {:?} @ {}..{}", s, span.start, span.end)
            }
            Event::Error { code, span } => {
                format!("Error {:?} @ {}..{}", code, span.start, span.end)
            }
        }
    }
}

/// Error codes for parse errors.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParseErrorCode {
    UnexpectedEof,
    UnexpectedChar,
    UnclosedCodeBlock,
    UnclosedCode,
    Unclosed,
}

/// Callback-based parser.
///
/// Uses true recursive descent - the call stack IS the element stack.

pub struct Parser<'a> {
    input: &'a [u8],
    pos: usize,
    mark_pos: usize,
    term_pos: usize,
    prepend_buf: Vec<u8>,
    /// Prepend bytes consumed by the most recent term() — spans extend back
    /// over them (PREPEND restores just-consumed source bytes).
    term_prepend_len: usize,
    line: u32,
    column: u32,
}

#[allow(unused_variables, dead_code)]
impl<'a> Parser<'a> {
    /// Create a new parser for the given input.
    pub fn new(input: &'a [u8]) -> Self {
