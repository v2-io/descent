        let offset = match (p1, p2) {
            (Some(x), Some(y)) => Some(x.min(y)),
            (Some(x), None) | (None, Some(x)) => Some(x),
            (None, None) => None,
        };
        match offset {
            Some(off) => {
                self.column += Self::char_count(&self.input[self.pos..self.pos + off]);
