//! Generated parser - DO NOT EDIT
//!
//! Generated by descent from elements.desc
//!
//! Callback-based recursive descent parser.
//! Call stack = element stack. True recursion handles nesting naturally.

use std::ops::Range;
/// Events emitted by the parser.
#[derive(Debug, Clone, PartialEq)]
pub enum Event<'a> {
    ElementStart { span: Range<usize> },
    ElementEnd { span: Range<usize> },
    Name { content: std::borrow::Cow<'a, [u8]>, span: Range<usize> },
    Text { content: std::borrow::Cow<'a, [u8]>, span: Range<usize> },
    Error { code: ParseErrorCode, span: Range<usize> },
}
impl<'a> Event<'a> {
    /// Format event as a single line for test output.
    pub fn format_line(&self) -> String {
        match self {
            Event::ElementStart { span } => {
                format!("ElementStart @ {}..{}", span.start, span.end)
            }
            Event::ElementEnd { span } => {
                format!("ElementEnd @ {}..{}", span.start, span.end)
            }
            Event::Name { content, span } => {
                let s = std::str::from_utf8(content.as_ref()).unwrap_or("<invalid utf8>");
                format!("Name {:?} @ {}..{}", s, span.start, span.end)
            }
            Event::Text { content, span } => {
                let s = std::str::from_utf8(content.as_ref()).unwrap_or("<invalid utf8>");
                format!("Text {:?} @ {}..{}", s, span.start, span.end)
            }
            Event::Error { code, span } => {
                format!("Error {:?} @ {}..{}", code, span.start, span.end)
            }
        }
    }
}

/// Error codes for parse errors.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParseErrorCode {
    UnexpectedEof,
    UnexpectedChar,
    UnclosedText,
}

/// Callback-based parser.
///
/// Uses true recursive descent - the call stack IS the element stack.

pub struct Parser<'a> {
    input: &'a [u8],
    pos: usize,
    mark_pos: usize,
    term_pos: usize,
    prepend_buf: Vec<u8>,
    line: u32,
    column: u32,
}

#[allow(unused_variables, dead_code)]
impl<'a> Parser<'a> {
    /// Create a new parser for the given input.
    pub fn new(input: &'a [u8]) -> Self {
        Self {
            input,
            pos: 0,
            mark_pos: 0,
            term_pos: 0,
            prepend_buf: Vec::new(),
            line: 1,
            column: 1,
        }
    }

    /// Parse the input, calling the callback for each event.
    ///
    /// The callback receives events in document order.
    /// For backpressure, have the callback send to a bounded channel.
    pub fn parse<F>(mut self, mut on_event: F)
    where
        F: FnMut(Event<'a>),
    {
        self.parse_document(&mut on_event);
    }

    // ========== Helpers ==========
    #[inline(always)]
    fn peek(&self) -> Option<u8> {
        self.input.get(self.pos).copied()
    }

    /// Format a byte for trace display (shows printable chars or escape codes).
    fn trace_byte(b: Option<u8>) -> String {
        match b {
            None => "EOF".to_string(),
            Some(b'\n') => "'\\n'".to_string(),
            Some(b'\t') => "'\\t'".to_string(),
            Some(b'\r') => "'\\r'".to_string(),
            Some(b' ') => "' '".to_string(),
            Some(b) if b.is_ascii_graphic() => format!("'{}'", b as char),
            Some(b) => format!("0x{:02x}", b),
        }
    }

    /// Format accumulated content for trace display (truncated).
    /// Shows slice content only (prepend buffer shown separately if non-empty).
    fn trace_content(&self) -> String {
        let end = if self.term_pos != usize::MAX { self.term_pos } else { self.pos };
        let slice = &self.input[self.mark_pos..end];
        let prepend_info = if self.prepend_buf.is_empty() {
            String::new()
        } else {
            format!("+{}", self.prepend_buf.len())
        };
        if slice.is_empty() && self.prepend_buf.is_empty() {
            return "[]".to_string();
        }
        let s = std::str::from_utf8(slice).unwrap_or("<binary>");
        if s.len() > 32 {
            format!("[{:?}...]{}", &s[..32], prepend_info)
        } else {
            format!("[{:?}]{}", s, prepend_info)
        }
    }

    #[inline(always)]
    fn eof(&self) -> bool {
        self.pos >= self.input.len()
    }

    #[inline(always)]
    fn advance(&mut self) {
        if self.pos < self.input.len() {
            if self.input[self.pos] == b'\n' {
                self.line += 1;
                self.column = 1;
            } else {
                self.column += 1;
            }
            self.pos += 1;
        }
    }

    #[inline(always)]
    fn mark(&mut self) {
        self.mark_pos = self.pos;
        self.term_pos = usize::MAX; // Sentinel: TERM not yet called
        // Note: prepend_buf is NOT cleared here - it persists until term() consumes it.
        // This allows PREPEND to be called before a nested function that does MARK.
    }

    /// Prepend bytes to the accumulation buffer.
    /// Empty slice is naturally a no-op.
    #[inline(always)]
    fn prepend_bytes(&mut self, bytes: &[u8]) {
        self.prepend_buf.extend_from_slice(bytes);
    }

    /// Get accumulated content from MARK to TERM, including any prepended bytes.
    /// Returns Cow::Borrowed when no prepend (zero-copy), Cow::Owned when prepend used.
    #[inline(always)]
    fn term(&mut self) -> std::borrow::Cow<'a, [u8]> {
        // Use term_pos if set after mark, otherwise use current pos
        let end = if self.term_pos != usize::MAX { self.term_pos } else { self.pos };
        let slice = &self.input[self.mark_pos..end];
        if self.prepend_buf.is_empty() {
            std::borrow::Cow::Borrowed(slice)
        } else {
            let mut combined = std::mem::take(&mut self.prepend_buf);
            combined.extend_from_slice(slice);
            std::borrow::Cow::Owned(combined)
        }
    }

    #[inline(always)]
    fn span(&self) -> Range<usize> {
        self.pos..self.pos
    }

    #[inline(always)]
    fn span_from_mark(&self) -> Range<usize> {
        // Use term_pos if set after mark, otherwise use current pos
        let end = if self.term_pos != usize::MAX { self.term_pos } else { self.pos };
        self.mark_pos..end
    }

    #[inline(always)]
    fn col(&self) -> i32 {
        self.column as i32
    }

    // ========== SCAN Methods (SIMD-accelerated via memchr) ==========
    // '\n' is included in scan targets by the generator for line tracking.
    // When '\n' is found, caller handles line/column update. No newlines
    // exist between start and found position, so we just add offset to column.
    /// Scan forward to find first occurrence of b1.
    #[inline(always)]
    fn scan_to1(&mut self, b1: u8) -> Option<u8> {
        match memchr::memchr(b1, &self.input[self.pos..]) {
            Some(offset) => {
                self.column += offset as u32;
                self.pos += offset;
                Some(self.input[self.pos])
            }
            None => {
                self.column += (self.input.len() - self.pos) as u32;
                self.pos = self.input.len();
                None
            }
        }
    }

    // ========== Generated Parse Functions ==========
    /// Parse document
    fn parse_document<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L20 ENTER document | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L21 document:main EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
            match self.peek() {
                Some(b'\n') => {
                    eprintln!("TRACE: L22 document:main.blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                }
                Some(b' ' | b'\t') => {
                    eprintln!("TRACE: L23 document:main.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                }
                Some(b'|') => {
                    eprintln!("TRACE: L24 document:main.pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_element(0, on_event);
                    continue;
                }
                _ => {
                    eprintln!("TRACE: L25 document:main.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text(0, on_event);
                    continue;
                }
            }
        }
    }

    /// Parse element -> Element
    fn parse_element<F>(&mut self, col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L31 ENTER element | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::ElementStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Identity, AfterName, Content, Children, Check,  }
        let mut state = State::Identity;
        loop {
            match state {
                State::Identity => {
                    if self.eof() {
                        eprintln!("TRACE: L32 element:identity EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'a' | b'b' | b'c' | b'd' | b'e' | b'f' | b'g' | b'h' | b'i' | b'j' | b'k' | b'l' | b'm' | b'n' | b'o' | b'p' | b'q' | b'r' | b's' | b't' | b'u' | b'v' | b'w' | b'x' | b'y' | b'z' | b'A' | b'B' | b'C' | b'D' | b'E' | b'F' | b'G' | b'H' | b'I' | b'J' | b'K' | b'L' | b'M' | b'N' | b'O' | b'P' | b'Q' | b'R' | b'S' | b'T' | b'U' | b'V' | b'W' | b'X' | b'Y' | b'Z') => {
                            eprintln!("TRACE: L33 element:identity.name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    state = State::AfterName;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L34 element:identity.quoted | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_name(on_event);
                    state = State::AfterName;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L35 element:identity.anon | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::AfterName => {
                    if self.eof() {
                        eprintln!("TRACE: L37 element:after_name EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L38 element:after_name.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L39 element:after_name.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L40 element:after_name.inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text(col, on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L42 element:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L43 element:content.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L44 element:content.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L45 element:content.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text(col, on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::Children => {
                    if self.eof() {
                        eprintln!("TRACE: L47 element:children EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L48 element:children.blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L49 element:children.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Check;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L50 element:children.dedent | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ElementEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Check => {
                    if self.eof() {
                        eprintln!("TRACE: L52 element:check EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L53 element:check.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ if self.col() <= col => {
                            eprintln!("TRACE: L54 element:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ElementEnd { span: self.span() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L55 element:check.child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_element(self.col(), on_event);
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L56 element:check.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text(self.col(), on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse name -> Name
    fn parse_name<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L61 ENTER name | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L62 name:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                return;
            }
            match self.peek() {
                Some(b'a' | b'b' | b'c' | b'd' | b'e' | b'f' | b'g' | b'h' | b'i' | b'j' | b'k' | b'l' | b'm' | b'n' | b'o' | b'p' | b'q' | b'r' | b's' | b't' | b'u' | b'v' | b'w' | b'x' | b'y' | b'z' | b'A' | b'B' | b'C' | b'D' | b'E' | b'F' | b'G' | b'H' | b'I' | b'J' | b'K' | b'L' | b'M' | b'N' | b'O' | b'P' | b'Q' | b'R' | b'S' | b'T' | b'U' | b'V' | b'W' | b'X' | b'Y' | b'Z' | b'0' | b'1' | b'2' | b'3' | b'4' | b'5' | b'6' | b'7' | b'8' | b'9' | b'_' | b'-') => {
                    eprintln!("TRACE: L63 name:main.cont | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                }
                _ => {
                    eprintln!("TRACE: L64 name:main.done | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                    return;
                }
            }
        }
    }

    /// Parse text -> Text
    fn parse_text<F>(&mut self, col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L70 ENTER text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to1(b'\n') {
                Some(b'\n') => {
                    eprintln!("TRACE: L72 text:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    eprintln!("TRACE: L71 text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }
}

// ============================================================================
// Streaming Parser (multi-chunk support)
// ============================================================================
/// Result of parsing a chunk in streaming mode.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParseResult {
    /// Parsing completed successfully (EOF reached).
    Complete,
    /// More data needed - provide another chunk.
    NeedMoreData,
}

/// Event with owned content for streaming across chunk boundaries.
#[derive(Debug, Clone, PartialEq)]
pub enum StreamEvent {
    ElementStart { span: Range<usize> },
    ElementEnd { span: Range<usize> },
    Name { content: Vec<u8>, span: Range<usize> },
    Text { content: Vec<u8>, span: Range<usize> },
    Error { code: ParseErrorCode, span: Range<usize> },
}
impl StreamEvent {
    /// Convert from borrowed Event to owned StreamEvent.
    fn from_event(event: Event<'_>, offset: usize) -> Self {
        match event {
            Event::ElementStart { span } => {
                StreamEvent::ElementStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ElementEnd { span } => {
                StreamEvent::ElementEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::Name { content, span } => {
                StreamEvent::Name {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Text { content, span } => {
                StreamEvent::Text {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Error { code, span } => {
                StreamEvent::Error { code, span: (span.start + offset)..(span.end + offset) }
            }
        }
    }
}

/// Streaming parser for chunk-by-chunk input.
///
/// Wraps the single-buffer `Parser` to handle input arriving in chunks.
/// Buffers incomplete content across chunk boundaries.
///
/// # Example
///
/// ```ignore
/// let mut parser = StreamingParser::new();
/// loop {
///     match parser.parse(chunk, |event| handle(event)) {
///         ParseResult::Complete => break,
///         ParseResult::NeedMoreData => {
///             chunk = get_next_chunk();
///             if chunk.is_empty() {
///                 parser.finish(|event| handle(event));
///                 break;
///             }

///         }

///     }

/// }

/// ```

pub struct StreamingParser {
    /// Buffer for incomplete content at chunk boundaries.
    buffer: Vec<u8>,
    /// Maximum buffer size before error (default 4KB).
    max_buffer: usize,
    /// Global byte offset for span calculation.
    global_offset: usize,
    /// Line number (persists across chunks).
    line: u32,
    /// Column number (persists across chunks).
    column: u32,
}
impl Default for StreamingParser {
    fn default() -> Self {
        Self::new()
    }
}
impl StreamingParser {
    /// Create a new streaming parser with default settings.
    pub fn new() -> Self {
        Self::with_max_buffer(4096)
    }

    /// Create a streaming parser with custom buffer limit.
    pub fn with_max_buffer(max_buffer: usize) -> Self {
        Self {
            buffer: Vec::new(),
            max_buffer,
            global_offset: 0,
            line: 1,
            column: 1,
        }
    }

    /// Parse a chunk of input, emitting events for complete lines.
    ///
    /// Uses line-oriented streaming: only parses complete lines (ending in `\n`).
    /// Incomplete lines are buffered until more data arrives.
    ///
    /// Returns `NeedMoreData` if the chunk ends mid-line.
    /// Call `finish()` after the last chunk to handle any remaining content.
    pub fn parse<F>(&mut self, chunk: &[u8], mut on_event: F) -> ParseResult
    where
        F: FnMut(StreamEvent),
    {
        // Append new chunk to buffer
        self.buffer.extend_from_slice(chunk);
        if self.buffer.is_empty() {
            return ParseResult::NeedMoreData;
        }

        // Check buffer size limit
        if self.buffer.len() > self.max_buffer {
            on_event(StreamEvent::Error {
                code: ParseErrorCode::UnexpectedEof, // Buffer overflow
                span: self.global_offset..self.global_offset,
            });
            self.buffer.clear();
            return ParseResult::Complete;
        }

        // Find last complete line (ending with \n)
        let last_newline = self.buffer.iter().rposition(|&b| b == b'\n');
        let parse_end = match last_newline {
            Some(pos) => pos + 1, // Include the newline
            None => return ParseResult::NeedMoreData, // No complete line yet
        };
        // Extract complete lines to parse
        let to_parse: Vec<u8> = self.buffer.drain(..parse_end).collect();
        let offset = self.global_offset;
        // Parse complete lines
        let mut inner = Parser::new(&to_parse);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
        // Update state
        self.global_offset += to_parse.len();
        for &b in &to_parse {
            if b == b'\n' {
                self.line += 1;
                self.column = 1;
            } else {
                self.column += 1;
            }
        }
        ParseResult::NeedMoreData
    }

    /// Signal end of input and handle any remaining buffered content.
    ///
    /// This triggers EOF handling for any incomplete constructs.
    pub fn finish<F>(mut self, mut on_event: F)
    where
        F: FnMut(StreamEvent),
    {
        if self.buffer.is_empty() {
            return;
        }

        // Parse remaining buffer - this will hit EOF
        let input = std::mem::take(&mut self.buffer);
        let offset = self.global_offset;
        let mut inner = Parser::new(&input);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
    }

    /// Returns the current global byte offset.
    pub fn offset(&self) -> usize {
        self.global_offset
    }

    /// Returns the current line number.
    pub fn line(&self) -> u32 {
        self.line
    }

    /// Returns the current column number.
    pub fn column(&self) -> u32 {
        self.column
    }
}

