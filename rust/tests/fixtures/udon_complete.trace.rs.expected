                        eprintln!("TRACE: L175 parse_element_identity:class EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'.') => {
                            eprintln!("TRACE: L176 parse_element_identity:class | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
