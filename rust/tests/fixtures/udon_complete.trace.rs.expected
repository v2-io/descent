                            eprintln!("TRACE: L325 element:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, elem_col, b"'", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::ChildPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L327 element:child_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L328 element:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::AfterChild;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) || b == b'\'' || b == b'[' || b == b'.' || b == b'?' || b == b'!' || b == b'*' || b == b'+' => {
                            eprintln!("TRACE: L329 element:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_element(col, elem_col, on_event);
                    state = State::AfterChild;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L330 element:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, elem_col, b"|", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::AfterChild => {
                    eprintln!("TRACE: L334 element:after_child UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    state = State::Children;
                    continue;
                }
            }
        }
    }

    /// Parse name -> Name
    fn parse_name<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L341 ENTER name | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L342 name:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                return;
            }
            match self.peek() {
                Some(b) if Self::is_xlbl_cont(b) => {
                    eprintln!("TRACE: L343 name:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                }
                _ => {
                    eprintln!("TRACE: L344 name:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                    return;
                }
            }
        }
    }

    /// Parse skip_single_quoted
    fn parse_skip_single_quoted<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L350 ENTER skip_single_quoted | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            match self.scan_to3(b'\n', b'\'', b'\\') {
                Some(b'\'') => {
                    eprintln!("TRACE: L352 skip_single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                }
                Some(b'\\') => {
                    eprintln!("TRACE: L353 skip_single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.advance();
                    continue;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L351 skip_single_quoted:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse quoted_name -> Name
    fn parse_quoted_name<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L357 ENTER quoted_name | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L358 quoted_name:main EOF | term={} pos={}", self.trace_content(), self.pos);
