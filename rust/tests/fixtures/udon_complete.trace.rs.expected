    /// Parse array -> Array
    fn parse_array<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L494 ENTER array | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::ArrayStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Entry, Items,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    if self.eof() {
                        eprintln!("TRACE: L495 array:entry EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedArray, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L496 array:entry | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Items;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: array:entry UNHANDLED | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                            return;
                        }
                    }
                }
                State::Items => {
                    if self.eof() {
                        eprintln!("TRACE: L497 array:items EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedArray, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b']') => {
                            eprintln!("TRACE: L498 array:items | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::ArrayEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L499 array:items | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L500 array:items | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_value(1, b']', on_event);
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse prose
    fn parse_prose<F>(&mut self, line_col: i32, parent_col: i32, prepend: &'static [u8], on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L509 ENTER prose | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                    if parent_col >= 0 && line_col <= parent_col {
                    return;
                    }
        loop {
            if self.eof() {
                eprintln!("TRACE: L512 prose:content EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
                    eprintln!("TRACE: L513 prose:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text(line_col, parent_col, prepend, on_event);
                    return;
        }
    }

    /// Parse prose_backticks
    fn parse_prose_backticks<F>(&mut self, line_col: i32, parent_col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L517 ENTER prose_backticks | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                    if parent_col >= 0 && line_col <= parent_col {
                    return;
                    }
        loop {
            if self.eof() {
                eprintln!("TRACE: L520 prose_backticks:content EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
                    eprintln!("TRACE: L521 prose_backticks:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text_backticks(line_col, parent_col, on_event);
                    return;
        }
    }

    /// Parse text_backticks
    fn parse_text_backticks<F>(&mut self, line_col: i32, parent_col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L527 ENTER text_backticks | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Entry, Main, CheckPipe, CheckSemi, CheckBang, AfterInline,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    eprintln!("TRACE: L529 text_backticks:entry UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b"`");
                    self.prepend_bytes(b"`");
                    state = State::Main;
                    continue;
                }
                State::Main => {
                    match self.scan_to4(b'\n', b'|', b';', b'!') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L533 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L534 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L535 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L536 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L531 text_backticks:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L539 text_backticks:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L541 text_backticks:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L542 text_backticks:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L545 text_backticks:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L547 text_backticks:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L548 text_backticks:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L550 text_backticks:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L552 text_backticks:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L553 text_backticks:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterInline => {
                    if self.eof() {
                        eprintln!("TRACE: L556 text_backticks:after_inline EOF | term={} pos={}", self.trace_content(), self.pos);
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L557 text_backticks:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L559 text_backticks:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse freeform -> Freeform
    fn parse_freeform<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L569 ENTER freeform | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::FreeformStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Lang, LineStart, Content, Line, MaybeEnd1, MaybeEnd2,  }
        let mut state = State::Lang;
        loop {
            match state {
                State::Lang => {
                    if self.eof() {
                        eprintln!("TRACE: L570 freeform:lang EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L571 freeform:lang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::LineStart;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L572 freeform:lang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    self.scan_to1(b'\n');
                    self.advance();
                    state = State::LineStart;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L573 freeform:lang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::LineStart;
                    continue;
                        }
                    }
                }
                State::LineStart => {
                    if self.eof() {
                        eprintln!("TRACE: L576 freeform:line_start EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L577 freeform:line_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L578 freeform:line_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L581 freeform:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L582 freeform:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'`') => {
                            eprintln!("TRACE: L583 freeform:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::MaybeEnd1;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L584 freeform:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::Line => {
                    eprintln!("TRACE: L587 freeform:line UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.scan_to1(b'\n');
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::LineStart;
                    continue;
                }
                State::MaybeEnd1 => {
                    if self.eof() {
                        eprintln!("TRACE: L590 freeform:maybe_end1 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L591 freeform:maybe_end1 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::MaybeEnd2;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L592 freeform:maybe_end1 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::MaybeEnd2 => {
                    if self.eof() {
                        eprintln!("TRACE: L594 freeform:maybe_end2 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L595 freeform:maybe_end2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::FreeformEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L596 freeform:maybe_end2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Line;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse text
    fn parse_text<F>(&mut self, line_col: i32, parent_col: i32, prepend: &'static [u8], on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L604 ENTER text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Entry, Main, CheckPipe, CheckSemi, CheckBang, AfterInline,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    eprintln!("TRACE: L606 text:entry UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(prepend);
                    state = State::Main;
                    continue;
                }
                State::Main => {
                    match self.scan_to4(b'\n', b'|', b';', b'!') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L610 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L611 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L612 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L613 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L608 text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L616 text:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L618 text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L619 text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L622 text:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L624 text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L625 text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L627 text:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L629 text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L630 text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterInline => {
                    if self.eof() {
                        eprintln!("TRACE: L633 text:after_inline EOF | term={} pos={}", self.trace_content(), self.pos);
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L634 text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L636 text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse sameline_text
    fn parse_sameline_text<F>(&mut self, elem_col: i32, prepend: &'static [u8], on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L644 ENTER sameline_text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Entry, Main, CheckPipe, CheckPipeElemCol, CheckSemi, CheckBang, AfterInline,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    eprintln!("TRACE: L646 sameline_text:entry UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(prepend);
                    state = State::Main;
                    continue;
                }
                State::Main => {
                    match self.scan_to4(b'\n', b'|', b';', b'!') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L650 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L651 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L652 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L653 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L648 sameline_text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L656 sameline_text:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L658 sameline_text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) || b == b'\'' || b == b'[' || b == b'.' || b == b'?' || b == b'!' || b == b'*' || b == b'+' => {
                            eprintln!("TRACE: L659 sameline_text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckPipeElemCol;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L660 sameline_text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckPipeElemCol => {
                    if self.eof() {
                        eprintln!("TRACE: L663 sameline_text:check_pipe_elem_col EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        _ if self.col() - 1 <= elem_col => {
                            eprintln!("TRACE: L664 sameline_text:check_pipe_elem_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L665 sameline_text:check_pipe_elem_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.parse_element(self.col() - 1, elem_col, on_event);
                    state = State::AfterInline;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L667 sameline_text:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L669 sameline_text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L670 sameline_text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.parse_line_comment_content(on_event);
                    return;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L672 sameline_text:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L674 sameline_text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L675 sameline_text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterInline => {
                    if self.eof() {
                        eprintln!("TRACE: L678 sameline_text:after_inline EOF | term={} pos={}", self.trace_content(), self.pos);
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L679 sameline_text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L681 sameline_text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse line_comment -> Comment
    fn parse_line_comment<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L698 ENTER line_comment | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::CommentStart { span: start_span.clone() });
        let comment_col: i32 = self.col() - 1;
        let mut content_base: i32 = -1;
        let mut col: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Check, FirstLine, Children, ChildrenWs, CheckContinuation, AtContentBase, ContContent, ContLine,  }
        let mut state = State::Check;
        loop {
            match state {
                State::Check => {
                    if self.eof() {
                        eprintln!("TRACE: L699 line_comment:check EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L700 line_comment:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_comment_text_braced(on_event);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L701 line_comment:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::FirstLine;
                    continue;
                        }
                    }
                }
                State::FirstLine => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L706 line_comment:first_line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L704 line_comment:first_line EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Children => {
                    if self.eof() {
                        eprintln!("TRACE: L711 line_comment:children EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L713 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L714 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    col = 1;
                    state = State::ChildrenWs;
                    continue;
                        }
                        Some(b'\t') => {
                            eprintln!("TRACE: L715 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L716 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::ChildrenWs => {
                    if self.eof() {
                        eprintln!("TRACE: L719 line_comment:children_ws EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if content_base >= 0 && col >= content_base => {
                            eprintln!("TRACE: L721 line_comment:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::AtContentBase;
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L722 line_comment:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    col += 1;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L723 line_comment:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckContinuation;
                    continue;
                        }
                    }
                }
                State::CheckContinuation => {
                    if self.eof() {
                        eprintln!("TRACE: L726 line_comment:check_continuation EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= comment_col => {
                            eprintln!("TRACE: L727 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        Some(b'|' | b':' | b'!' | b';') => {
                            eprintln!("TRACE: L728 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ if content_base < 0 => {
                            eprintln!("TRACE: L731 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    content_base = col;
                    self.mark();
                    state = State::ContLine;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L733 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Warning { content: std::borrow::Cow::Borrowed(b"Inconsistent indentation"), span: self.span() });
                    content_base = col;
                    self.mark();
                    state = State::ContLine;
                    continue;
                        }
                    }
                }
                State::AtContentBase => {
                    if self.eof() {
                        eprintln!("TRACE: L736 line_comment:at_content_base EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'|' | b':' | b'!' | b';') => {
                            eprintln!("TRACE: L737 line_comment:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L738 line_comment:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::ContContent;
                    continue;
                        }
                    }
                }
                State::ContContent => {
                    if self.eof() {
                        eprintln!("TRACE: L741 line_comment:cont_content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ') => {
                            eprintln!("TRACE: L742 line_comment:cont_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L743 line_comment:cont_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::ContLine;
                    continue;
                        }
                    }
                }
                State::ContLine => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L747 line_comment:cont_line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L745 line_comment:cont_line EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
            }
        }
    }

    /// Parse line_comment_content -> Comment
    fn parse_line_comment_content<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L753 ENTER line_comment_content | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::CommentStart { span: start_span.clone() });
                    self.mark();
                    self.scan_to1(b'\n');
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
        on_event(Event::CommentEnd { span: self.span() });
    }

    /// Parse skip_brace_balanced
    fn parse_skip_brace_balanced<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L759 ENTER skip_brace_balanced | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let mut depth: i32 = 1;
        #[derive(Clone, Copy)]
        enum State { Main, Check,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    match self.scan_to3(b'\n', b'{', b'}') {
                        Some(b'{') => {
                            eprintln!("TRACE: L761 skip_brace_balanced:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    depth += 1;
                    continue;
                        }
                        Some(b'}') => {
                            eprintln!("TRACE: L762 skip_brace_balanced:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    depth -= 1;
                    state = State::Check;
                    continue;
                        }
                        Some(b'\n') => {
                            self.advance();
                        }
                        None => {
                            eprintln!("TRACE: L760 skip_brace_balanced:main EOF | term={} pos={}", self.trace_content(), self.pos);
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Check => {
                    if self.eof() {
                        eprintln!("TRACE: L765 skip_brace_balanced:check EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        _ if depth == 0 => {
                            eprintln!("TRACE: L766 skip_brace_balanced:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L767 skip_brace_balanced:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse brace_comment -> Comment
    fn parse_brace_comment<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L772 ENTER brace_comment | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::CommentStart { span: start_span.clone() });
        loop {
            if self.eof() {
                eprintln!("TRACE: L773 brace_comment:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::CommentEnd { span: self.span() });
                return;
            }
                    eprintln!("TRACE: L774 brace_comment:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_comment_text_braced(on_event);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
        }
    }

    /// Parse comment_text_braced
    fn parse_comment_text_braced<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L778 ENTER comment_text_braced | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                    self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L779 comment_text_braced:main EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
                    eprintln!("TRACE: L780 comment_text_braced:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    return;
        }
    }

    /// Parse embedded -> Embedded
    fn parse_embedded<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L788 ENTER embedded | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::EmbeddedStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Identity, PostIdentity, PreContent,  }
        let mut state = State::Identity;
        loop {
            match state {
                State::Identity => {
                    eprintln!("TRACE: L791 embedded:identity UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.parse_parse_element_identity(b'}', on_event);
                    state = State::PostIdentity;
                    continue;
                }
                State::PostIdentity => {
                    if self.eof() {
                        eprintln!("TRACE: L793 embedded:post_identity EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::EmbeddedEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L794 embedded:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L795 embedded:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::PreContent;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L796 embedded:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_embed_content(on_event);
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::PreContent => {
                    if self.eof() {
                        eprintln!("TRACE: L798 embedded:pre_content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::EmbeddedEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L799 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L800 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L801 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_attr_embedded(on_event);
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L802 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_embed_content(on_event);
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse embed_content -> Text
    fn parse_embed_content<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L808 ENTER embed_content | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, CheckPipe, CheckSemi, CheckBang,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    match self.scan_to6(b'}', b'|', b';', b'!', b'"', b'\'') {
                        Some(b'}') => {
                            eprintln!("TRACE: L810 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L811 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L812 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L813 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        Some(b'"') => {
                            eprintln!("TRACE: L814 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_double_quoted(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L815 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_single_quoted(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L809 embed_content:main EOF | term={} pos={}", self.trace_content(), self.pos);
                            on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                            on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L818 embed_content:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                        on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L820 embed_content:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L821 embed_content:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b"|");
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L823 embed_content:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                        on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L825 embed_content:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L826 embed_content:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b";");
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L828 embed_content:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                        on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L830 embed_content:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L831 embed_content:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b"!");
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse block_directive -> Directive
    fn parse_block_directive<F>(&mut self, line_col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L839 ENTER block_directive | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::DirectiveStart { span: start_span.clone() });
        let mut col: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Dispatch, RawKind, RawColon, RawEol, RawContent, RawCheck, RawLine, AfterName, Condition, Children, CheckChild, ChildDispatch, ChildApos, ChildPipe,  }
        let mut state = State::Dispatch;
        loop {
            match state {
                State::Dispatch => {
                    if self.eof() {
                        eprintln!("TRACE: L840 block_directive:dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b':') => {
                            eprintln!("TRACE: L841 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RawKind;
                    continue;
                        }
                        Some(b'{') => {
                            eprintln!("TRACE: L842 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L843 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    state = State::AfterName;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L844 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawKind => {
                    if self.eof() {
                        eprintln!("TRACE: L847 block_directive:raw_kind EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L848 block_directive:raw_kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    on_event(Event::Raw { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    state = State::RawColon;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L849 block_directive:raw_kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawColon => {
                    if self.eof() {
                        eprintln!("TRACE: L851 block_directive:raw_colon EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b':') => {
                            eprintln!("TRACE: L852 block_directive:raw_colon | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RawEol;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L853 block_directive:raw_colon | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawEol => {
                    match self.scan_to3(b'\n', b' ', b'\t') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L856 block_directive:raw_eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RawContent;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L857 block_directive:raw_eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L855 block_directive:raw_eol EOF | term={} pos={}", self.trace_content(), self.pos);
                            on_event(Event::DirectiveEnd { span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::RawContent => {
                    if self.eof() {
                        eprintln!("TRACE: L861 block_directive:raw_content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L862 block_directive:raw_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L863 block_directive:raw_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.parse_count_indent(on_event);
                    state = State::RawCheck;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L864 block_directive:raw_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawCheck => {
                    if self.eof() {
                        eprintln!("TRACE: L866 block_directive:raw_check EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= line_col => {
                            eprintln!("TRACE: L867 block_directive:raw_check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L868 block_directive:raw_check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::RawLine;
                    continue;
                        }
                    }
                }
                State::RawLine => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L872 block_directive:raw_line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::RawContent { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::RawContent;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L870 block_directive:raw_line EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::RawContent { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::AfterName => {
                    if self.eof() {
                        eprintln!("TRACE: L876 block_directive:after_name EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L877 block_directive:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L878 block_directive:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Condition;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L879 block_directive:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::Condition => {
                    if self.eof() {
                        eprintln!("TRACE: L881 block_directive:condition EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L882 block_directive:condition | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L883 block_directive:condition | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.parse_directive_args(on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::Children => {
                    if self.eof() {
                        eprintln!("TRACE: L886 block_directive:children EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L887 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L888 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.parse_count_indent(on_event);
                    state = State::CheckChild;
                    continue;
                        }
                        Some(b'\t') => {
                            eprintln!("TRACE: L889 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::NoTabs, span: self.span() });
                    self.scan_to1(b'\n');
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L890 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.col() - 1;
                    state = State::CheckChild;
                    continue;
                        }
                    }
                }
                State::CheckChild => {
                    if self.eof() {
                        eprintln!("TRACE: L892 block_directive:check_child EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= line_col => {
                            eprintln!("TRACE: L893 block_directive:check_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L894 block_directive:check_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::ChildDispatch;
                    continue;
                        }
                    }
                }
                State::ChildDispatch => {
                    if self.eof() {
                        eprintln!("TRACE: L896 block_directive:child_dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'|') => {
                            eprintln!("TRACE: L897 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildPipe;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L898 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_attr(on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L899 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_directive(col, on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L900 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_line_comment(on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L901 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildApos;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L902 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, line_col, b"", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::ChildApos => {
                    if self.eof() {
                        eprintln!("TRACE: L905 block_directive:child_apos EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'|') => {
                            eprintln!("TRACE: L906 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b"|", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L907 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b";", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L908 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b":", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L909 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b"!", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L910 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b"'", on_event);
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L911 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, line_col, b"'", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::ChildPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L913 block_directive:child_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L914 block_directive:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) || b == b'\'' || b == b'[' || b == b'.' || b == b'?' || b == b'!' || b == b'*' || b == b'+' => {
                            eprintln!("TRACE: L915 block_directive:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_element(col, line_col, on_event);
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L916 block_directive:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, line_col, b"|", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse directive_args -> Text
    fn parse_directive_args<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L920 ENTER directive_args | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
                    self.scan_to1(b'\n');
                    self.set_term(0);
        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
    }

    /// Parse sameline_directive
    fn parse_sameline_directive<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L925 ENTER sameline_directive | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L926 sameline_directive:dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
            match self.peek() {
                Some(b'{') => {
                    eprintln!("TRACE: L927 sameline_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_interpolation(on_event);
                    return;
                }
                Some(b':') => {
                    eprintln!("TRACE: L928 sameline_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_raw(on_event);
                    return;
                }
                _ => {
                    eprintln!("TRACE: L929 sameline_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_dir_body(on_event);
                    return;
                }
            }
        }
    }

    /// Parse interpolation -> Interpolation
    fn parse_interpolation<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L933 ENTER interpolation | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, Closing,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    match self.scan_to2(b'\n', b'}') {
                        Some(b'}') => {
                            eprintln!("TRACE: L936 interpolation:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::Closing;
                    continue;
                        }
                        Some(b'\n') => {
                            self.advance();
                        }
                        None => {
                            eprintln!("TRACE: L934 interpolation:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedInterpolation, span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Closing => {
                    if self.eof() {
                        eprintln!("TRACE: L939 interpolation:closing EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L940 interpolation:closing | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L941 interpolation:closing | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedInterpolation, span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse sameline_raw -> Directive
    fn parse_sameline_raw<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L947 ENTER sameline_raw | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::DirectiveStart { span: start_span.clone() });
        let mut depth: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Kind, Content, Scan, CheckClose,  }
        let mut state = State::Kind;
        loop {
            match state {
                State::Kind => {
                    if self.eof() {
                        eprintln!("TRACE: L948 sameline_raw:kind EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b':') => {
                            eprintln!("TRACE: L949 sameline_raw:kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L950 sameline_raw:kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    continue;
                        }
                    }
                }
                State::Content => {
                    eprintln!("TRACE: L953 sameline_raw:content UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    state = State::Scan;
                    continue;
                }
                State::Scan => {
                    match self.scan_to3(b'\n', b'{', b'}') {
                        Some(b'{') => {
                            eprintln!("TRACE: L956 sameline_raw:scan | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    depth += 1;
                    continue;
                        }
                        Some(b'}') => {
                            eprintln!("TRACE: L957 sameline_raw:scan | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckClose;
                    continue;
                        }
                        Some(b'\n') => {
                            self.advance();
                        }
                        None => {
                            eprintln!("TRACE: L955 sameline_raw:scan EOF | term={} pos={}", self.trace_content(), self.pos);
                            on_event(Event::DirectiveEnd { span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckClose => {
                    if self.eof() {
                        eprintln!("TRACE: L960 sameline_raw:check_close EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if depth > 0 => {
                            eprintln!("TRACE: L961 sameline_raw:check_close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    depth -= 1;
                    state = State::Scan;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L962 sameline_raw:check_close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::RawContent { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse sameline_dir_body -> Directive
    fn parse_sameline_dir_body<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L966 ENTER sameline_dir_body | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::DirectiveStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Name, AfterName, Args,  }
        let mut state = State::Name;
        loop {
            match state {
                State::Name => {
                    if self.eof() {
                        eprintln!("TRACE: L967 sameline_dir_body:name EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L968 sameline_dir_body:name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    state = State::AfterName;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L969 sameline_dir_body:name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::AfterName => {
                    if self.eof() {
                        eprintln!("TRACE: L971 sameline_dir_body:after_name EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L972 sameline_dir_body:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L973 sameline_dir_body:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Args;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L974 sameline_dir_body:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Args => {
                    if self.eof() {
                        eprintln!("TRACE: L976 sameline_dir_body:args EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L977 sameline_dir_body:args | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L978 sameline_dir_body:args | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse emit_bare_value
    fn parse_emit_bare_value<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L1018 ENTER emit_bare_value | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L1019 emit_bare_value:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
            }
                    eprintln!("TRACE: L1021 emit_bare_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
        }
    }

    /// Parse typed_value
    fn parse_typed_value<F>(&mut self, space_term: i32, bracket: u8, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L1030 ENTER typed_value | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                    self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, MaybeRef, Reference, CheckSpace, BlockSpace, Accumulate, AccumSpace, AccumBlock, NumSign, NumZero, NumZeroSpace, NumZeroBlock, NumDec, NumDecSpace, NumDecBlock, NumHex, NumHexSpace, NumHexBlock, NumOct, NumOctSpace, NumOctBlock, NumBin, NumBinSpace, NumBinBlock, NumFloatFrac, NumFloatFracSpace, NumFloatFracBlock, NumFloatExp, NumFloatExpSpace, NumFloatExpBlock, NumFloatExpDigits, NumFloatExpDSpace, NumFloatExpDBlock, NumRationalDenom, NumRationalSpace, NumRationalBlock, NumComplexSign, NumComplexImag, NumComplexImagSpace, NumComplexImagBlock, NumComplexImagFrac, NumComplexImagFracSpace, NumComplexImagFracBlock, NumComplexImagExp, NumComplexImagExpSpace, NumComplexImagExpBlock, NumComplexImagExpD, NumComplexImagExpDSpace, NumComplexImagExpDBlock, String, StringSpace, StringBlock,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        eprintln!("TRACE: L1031 typed_value:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L1033 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L1034 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckSpace;
                    continue;
                        }
                        Some(b) if b == bracket => {
                            eprintln!("TRACE: L1035 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'@') => {
                            eprintln!("TRACE: L1036 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::MaybeRef;
                    continue;
                        }
                        Some(b'0') => {
                            eprintln!("TRACE: L1037 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NumZero;
                    continue;
                        }
                        Some(b'1' | b'2' | b'3' | b'4' | b'5' | b'6' | b'7' | b'8' | b'9') => {
                            eprintln!("TRACE: L1038 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::NumDec;
                    continue;
                        }
                        Some(b'+' | b'-') => {
                            eprintln!("TRACE: L1039 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NumSign;
                    continue;
                        }
                        Some(b'a' | b'b' | b'c' | b'd' | b'e' | b'f' | b'g' | b'h' | b'i' | b'j' | b'k' | b'l' | b'm' | b'n' | b'o' | b'p' | b'q' | b'r' | b's' | b't' | b'u' | b'v' | b'w' | b'x' | b'y' | b'z' | b'A' | b'B' | b'C' | b'D' | b'E' | b'F' | b'G' | b'H' | b'I' | b'J' | b'K' | b'L' | b'M' | b'N' | b'O' | b'P' | b'Q' | b'R' | b'S' | b'T' | b'U' | b'V' | b'W' | b'X' | b'Y' | b'Z') => {
                            eprintln!("TRACE: L1040 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Accumulate;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L1041 typed_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                    }
                }
                State::MaybeRef => {
                    if self.eof() {
                        eprintln!("TRACE: L1044 typed_value:maybe_ref EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L1045 typed_value:maybe_ref | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.mark();
                    state = State::Reference;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L1046 typed_value:maybe_ref | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::String;
                    continue;
                        }
                    }
                }
                State::Reference => {
                    match self.scan_to2(b'\n', b']') {
                        Some(b']') => {
                            eprintln!("TRACE: L1049 typed_value:reference | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Reference { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    return;
                        }
                        Some(b'\n') => {
                            self.advance();
                        }
                        None => {
                            eprintln!("TRACE: L1048 typed_value:reference EOF | term={} pos={}", self.trace_content(), self.pos);
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckSpace => {
                    if self.eof() {
                        eprintln!("TRACE: L1052 typed_value:check_space EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        _ if space_term == 0 => {
                            eprintln!("TRACE: L1053 typed_value:check_space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::BlockSpace;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L1054 typed_value:check_space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                    }
                }
                State::BlockSpace => {
                    if self.eof() {
                        eprintln!("TRACE: L1056 typed_value:block_space EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b';') => {
                            eprintln!("TRACE: L1057 typed_value:block_space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L1058 typed_value:block_space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::Accumulate => {
                    if self.eof() {
                        eprintln!("TRACE: L1062 typed_value:accumulate EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    self.lookup_bare_kw_or_fallback(on_event);
                    return;
                    }
                    match self.peek() {
