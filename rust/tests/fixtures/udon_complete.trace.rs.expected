    /// Parse suffix
    fn parse_suffix<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L377 ENTER suffix | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L378 suffix:main EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
            match self.peek() {
                Some(b'?') => {
                    eprintln!("TRACE: L379 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"?"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                Some(b'!') => {
                    eprintln!("TRACE: L380 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"!"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                Some(b'*') => {
                    eprintln!("TRACE: L381 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                Some(b'+') => {
                    eprintln!("TRACE: L382 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"+"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                _ => {
                    eprintln!("TRACE: L383 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                }
            }
        }
    }

    /// Parse block_attr
    fn parse_block_attr<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L386 ENTER block_attr | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Key, ValueStart, PostValue,  }
        let mut state = State::Key;
        loop {
            match state {
                State::Key => {
                    if self.eof() {
                        eprintln!("TRACE: L387 block_attr:key EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L388 block_attr:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_attr_reference(on_event);
                    return;
                        }
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L389 block_attr:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_attr_key(on_event);
                    state = State::ValueStart;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L390 block_attr:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_attr_key_quoted(on_event);
                    state = State::ValueStart;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: block_attr:key UNHANDLED | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                            return;
                        }
                    }
                }
                State::ValueStart => {
                    if self.eof() {
                        eprintln!("TRACE: L392 block_attr:value_start EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L393 block_attr:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L394 block_attr:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L395 block_attr:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_value(0, b'\0', on_event);
                    state = State::PostValue;
                    continue;
                        }
                    }
                }
                State::PostValue => {
                    if self.eof() {
                        eprintln!("TRACE: L398 block_attr:post_value EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b';') => {
                            eprintln!("TRACE: L399 block_attr:post_value | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_line_comment_content(on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L400 block_attr:post_value | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                    }
                }
            }
        }
    }

