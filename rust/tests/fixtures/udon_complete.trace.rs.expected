    /// Parse count_indent -> INT
    fn parse_count_indent<F>(&mut self, on_event: &mut F) -> i32
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L115 ENTER count_indent | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let mut result: i32 = 0;
        loop {
            if self.eof() {
                eprintln!("TRACE: L116 count_indent:main EOF | term={} pos={}", self.trace_content(), self.pos);
                return 0;
            }
            match self.peek() {
                Some(b' ') => {
                    eprintln!("TRACE: L117 count_indent:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    result += 1;
                    continue;
                }
                _ => {
                    eprintln!("TRACE: L118 count_indent:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return result;
                }
            }
        }
    }

    /// Parse parse_element_identity
    fn parse_parse_element_identity<F>(&mut self, close: u8, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L133 ENTER parse_element_identity | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Identity, QuotedName, PostName, PostSuffix, Bracket, BracketClose, PostBracket, Class, PostClass,  }
        let mut state = State::Identity;
        loop {
            match state {
                State::Identity => {
                    if self.eof() {
                        eprintln!("TRACE: L134 parse_element_identity:identity EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
