                return;
            }
                    eprintln!("TRACE: L359 quoted_name:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_single_quoted(on_event);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                    return;
        }
    }

