    /// Parse value
    fn parse_value<F>(&mut self, space_term: i32, bracket: u8, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L463 ENTER value | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L464 value:start EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
            match self.peek() {
                Some(b'"') => {
                    eprintln!("TRACE: L465 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_double_quoted(on_event);
                    return;
                }
                Some(b'\'') => {
                    eprintln!("TRACE: L466 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_single_quoted(on_event);
                    return;
                }
                Some(b'[') => {
                    eprintln!("TRACE: L467 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_array(on_event);
                    return;
                }
                _ => {
                    eprintln!("TRACE: L468 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.parse_typed_value(space_term, bracket, on_event);
                    return;
                }
            }
        }
    }

    /// Parse value_bracket -> BareValue
    fn parse_value_bracket<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L472 ENTER value_bracket | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'\n', b']', b' ') {
                Some(b']') => {
                    eprintln!("TRACE: L474 value_bracket:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b' ') => {
                    eprintln!("TRACE: L475 value_bracket:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L473 value_bracket:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse double_quoted -> StringValue
    fn parse_double_quoted<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L480 ENTER double_quoted | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'\n', b'"', b'\\') {
                Some(b'"') => {
                    eprintln!("TRACE: L482 double_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\\') => {
                    eprintln!("TRACE: L483 double_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.advance();
                    continue;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L481 double_quoted:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedStringValue, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse single_quoted -> StringValue
    fn parse_single_quoted<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L486 ENTER single_quoted | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'\n', b'\'', b'\\') {
                Some(b'\'') => {
                    eprintln!("TRACE: L488 single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\\') => {
                    eprintln!("TRACE: L489 single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.advance();
                    continue;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L487 single_quoted:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedStringValue, span: self.span() });
