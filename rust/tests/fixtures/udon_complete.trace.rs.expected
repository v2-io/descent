/// Keyword lookup map for bare_kw.
/// Generated from |keywords[bare_kw] - O(1) perfect hash lookup.
static BARE_KW_KEYWORDS: phf::Map<&'static [u8], u8> = phf_map! {
    b"true" => 0u8,
    b"false" => 1u8,
    b"null" => 2u8,
    b"nil" => 3u8,
};
