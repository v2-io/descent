                        Some(b'\'') => {
                            eprintln!("TRACE: L178 parse_element_identity:class | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"$class"), span: self.span() });
                    self.advance();
                    self.parse_quoted_class(on_event);
                    state = State::PostClass;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L179 parse_element_identity:class | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
