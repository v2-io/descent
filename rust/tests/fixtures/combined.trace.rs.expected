    /// Parse name -> Name
    fn parse_name<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L364 ENTER name | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L365 name:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                return;
            }
            match self.peek() {
                Some(b) if Self::is_xlbl_cont(b) => {
                    eprintln!("TRACE: L366 name:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                }
                _ => {
                    eprintln!("TRACE: L367 name:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                    return;
                }
            }
        }
    }

    /// Parse skip_single_quoted
    fn parse_skip_single_quoted<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L373 ENTER skip_single_quoted | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            match self.scan_to3(b'\n', b'\'', b'\\') {
                Some(b'\'') => {
                    eprintln!("TRACE: L375 skip_single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                }
                Some(b'\\') => {
                    eprintln!("TRACE: L376 skip_single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.advance();
                    continue;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L374 skip_single_quoted:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse quoted_name -> Name
    fn parse_quoted_name<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L380 ENTER quoted_name | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L381 quoted_name:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                return;
            }
                    eprintln!("TRACE: L382 quoted_name:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_single_quoted(on_event);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::Name { content: self.term(), span: self.span_from_mark() });
                    return;
        }
    }

    /// Parse class_name -> BareValue
    fn parse_class_name<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L385 ENTER class_name | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
