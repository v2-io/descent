    // ========== Keyword Lookup: bare_kw ==========
    /// Look up accumulated content in bare_kw keywords.
    /// Returns true if a keyword matched (event emitted), false otherwise.
    fn lookup_bare_kw<F>(&mut self, on_event: &mut F) -> bool
    where
        F: FnMut(Event<'a>),
    {
        let content = self.term();
        if let Some(&id) = BARE_KW_KEYWORDS.get(content.as_ref()) {
            let span = self.span_from_mark();
            match id {
                0 => on_event(Event::BoolTrue { content, span }),
                1 => on_event(Event::BoolFalse { content, span }),
                2 => on_event(Event::Nil { content, span }),
                3 => on_event(Event::Nil { content, span }),
                _ => unreachable!("keyword map contains only valid ids"),
            }
            true
        } else {
            false
        }
    }

    /// Look up and emit keyword, or call fallback function.
    fn lookup_bare_kw_or_fallback<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        if !self.lookup_bare_kw(on_event) {
            self.parse_emit_bare_value(on_event);
        }
    }

    // ========== Generated Parse Functions ==========
    /// Parse document
    fn parse_document<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L66 ENTER document | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let mut col: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Line, Dispatch, CheckAt, CheckApos, CheckFreeform, CheckFreeform2, CheckPipe,  }
        let mut state = State::Line;
        loop {
            match state {
                State::Line => {
                    if self.eof() {
                        eprintln!("TRACE: L67 document:line EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L68 document:line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L69 document:line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.parse_count_indent(on_event);
                    state = State::Dispatch;
                    continue;
                        }
                        Some(b'\t') => {
                            eprintln!("TRACE: L70 document:line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::NoTabs, span: self.span() });
                    self.scan_to1(b'\n');
                    state = State::Line;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L71 document:line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.col() - 1;
                    state = State::Dispatch;
                    continue;
                        }
                    }
                }
                State::Dispatch => {
                    if self.eof() {
                        eprintln!("TRACE: L73 document:dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'|') => {
                            eprintln!("TRACE: L74 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L75 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_attr(on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L76 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_directive(col, on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L77 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_line_comment(on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b'@') => {
                            eprintln!("TRACE: L78 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckAt;
                    continue;
                        }
                        Some(b'`') => {
                            eprintln!("TRACE: L79 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckFreeform;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L80 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckApos;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L81 document:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, -1, b"", on_event);
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::CheckAt => {
                    if self.eof() {
                        eprintln!("TRACE: L84 document:check_at EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L85 document:check_at | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_reference(on_event);
                    state = State::Line;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L86 document:check_at | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, -1, b"@", on_event);
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::CheckApos => {
                    if self.eof() {
                        eprintln!("TRACE: L90 document:check_apos EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'|') => {
                            eprintln!("TRACE: L91 document:check_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, -1, b"|", on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L92 document:check_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, -1, b";", on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L93 document:check_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, -1, b":", on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L94 document:check_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, -1, b"!", on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L95 document:check_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, -1, b"'", on_event);
                    state = State::Line;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L96 document:check_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, -1, b"'", on_event);
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::CheckFreeform => {
                    if self.eof() {
                        eprintln!("TRACE: L98 document:check_freeform EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L99 document:check_freeform | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckFreeform2;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L100 document:check_freeform | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, -1, b"`", on_event);
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::CheckFreeform2 => {
                    if self.eof() {
                        eprintln!("TRACE: L102 document:check_freeform2 EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L103 document:check_freeform2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_freeform(on_event);
                    state = State::Line;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L104 document:check_freeform2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose_backticks(col, -1, on_event);
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L106 document:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b) if Self::is_xlbl_start(b) || b == b'\'' || b == b'[' || b == b'.' || b == b'?' || b == b'!' || b == b'*' || b == b'+' => {
                            eprintln!("TRACE: L107 document:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_element(col, -1, on_event);
                    state = State::Line;
                    continue;
                        }
                        Some(b'{') => {
                            eprintln!("TRACE: L108 document:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::Line;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L109 document:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, -1, b"|", on_event);
                    state = State::Line;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse count_indent -> INT
    fn parse_count_indent<F>(&mut self, on_event: &mut F) -> i32
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L116 ENTER count_indent | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let mut result: i32 = 0;
        loop {
            if self.eof() {
                eprintln!("TRACE: L117 count_indent:main EOF | term={} pos={}", self.trace_content(), self.pos);
                return 0;
            }
            match self.peek() {
                Some(b' ') => {
                    eprintln!("TRACE: L118 count_indent:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    result += 1;
                    continue;
                }
                _ => {
                    eprintln!("TRACE: L119 count_indent:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return result;
                }
            }
        }
    }

    /// Parse parse_element_identity
    fn parse_parse_element_identity<F>(&mut self, close: u8, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L134 ENTER parse_element_identity | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Identity, QuotedName, PostName, PostSuffix, Bracket, BracketClose, PostBracket, Class, PostClass,  }
        let mut state = State::Identity;
        loop {
            match state {
                State::Identity => {
                    if self.eof() {
                        eprintln!("TRACE: L135 parse_element_identity:identity EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b) if b == close => {
                            eprintln!("TRACE: L136 parse_element_identity:identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L137 parse_element_identity:identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    state = State::PostName;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L138 parse_element_identity:identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::QuotedName;
                    continue;
                        }
                        Some(b'[') => {
                            eprintln!("TRACE: L139 parse_element_identity:identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Bracket;
                    continue;
                        }
                        Some(b'.') => {
                            eprintln!("TRACE: L140 parse_element_identity:identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Class;
                    continue;
                        }
                        Some(b'?' | b'!' | b'*' | b'+') => {
                            eprintln!("TRACE: L141 parse_element_identity:identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_suffix(on_event);
                    state = State::PostSuffix;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L142 parse_element_identity:identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                    }
                }
                State::QuotedName => {
                    if self.eof() {
                        eprintln!("TRACE: L144 parse_element_identity:quoted_name EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
