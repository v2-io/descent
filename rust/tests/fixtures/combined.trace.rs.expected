    }

    /// Parse element -> Element
    fn parse_element<F>(&mut self, elem_col: i32, parent_col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L193 ENTER element | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::ElementStart { span: start_span.clone() });
        let mut content_base: i32 = -1;
        let mut col: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Identity, PostIdentity, PreContent, CheckSamelinePipe, CheckSamelineElemCol, CheckSamelineSemi, CheckSamelineBang, PostSamelineInline, PostChild, CheckPostPipeCol, Children, AfterNewline, ChildrenWs, AtContentBase, CheckChild, ChildDispatch, ChildDispatchDo, ChildCheckAt, DoProse, ChildCheckFreeform, ChildCheckFreeform2, ChildApos, ChildPipe, AfterChild, AfterContent,  }
        let mut state = State::Identity;
        loop {
            match state {
                State::Identity => {
                    eprintln!("TRACE: L196 element:identity UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.parse_parse_element_identity(0u8, on_event);
                    state = State::PostIdentity;
                    continue;
                }
                State::PostIdentity => {
                    if self.eof() {
                        eprintln!("TRACE: L198 element:post_identity EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L199 element:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L200 element:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::PreContent;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L201 element:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_text(elem_col, b"", on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::PreContent => {
                    if self.eof() {
                        eprintln!("TRACE: L203 element:pre_content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L204 element:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L205 element:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L206 element:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_attr(on_event);
                    continue;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L207 element:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSamelinePipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L208 element:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSamelineSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L209 element:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSamelineBang;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L210 element:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_text(elem_col, b"", on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::CheckSamelinePipe => {
                    if self.eof() {
                        eprintln!("TRACE: L212 element:check_sameline_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L213 element:check_sameline_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::PostChild;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) || b == b'\'' || b == b'[' || b == b'.' || b == b'?' || b == b'!' || b == b'*' || b == b'+' => {
                            eprintln!("TRACE: L214 element:check_sameline_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckSamelineElemCol;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L215 element:check_sameline_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_text(elem_col, b"|", on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::CheckSamelineElemCol => {
                    if self.eof() {
                        eprintln!("TRACE: L219 element:check_sameline_elem_col EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.col() - 1 <= elem_col => {
                            eprintln!("TRACE: L220 element:check_sameline_elem_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ElementEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L221 element:check_sameline_elem_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_element(self.col() - 1, elem_col, on_event);
                    state = State::PostChild;
                    continue;
                        }
                    }
                }
                State::CheckSamelineSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L223 element:check_sameline_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L224 element:check_sameline_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_brace_comment(on_event);
                    state = State::PostSamelineInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L225 element:check_sameline_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_line_comment_content(on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::CheckSamelineBang => {
                    if self.eof() {
                        eprintln!("TRACE: L227 element:check_sameline_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L228 element:check_sameline_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    state = State::PostSamelineInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L229 element:check_sameline_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_text(elem_col, b"!", on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::PostSamelineInline => {
                    if self.eof() {
                        eprintln!("TRACE: L232 element:post_sameline_inline EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::ElementEnd { span: self.span() });
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L233 element:post_sameline_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L235 element:post_sameline_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_text(elem_col, b"", on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::PostChild => {
                    if self.eof() {
                        eprintln!("TRACE: L237 element:post_child EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L238 element:post_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L239 element:post_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L240 element:post_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckPostPipeCol;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L241 element:post_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_text(elem_col, b"", on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::CheckPostPipeCol => {
                    if self.eof() {
                        eprintln!("TRACE: L245 element:check_post_pipe_col EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.col() <= elem_col => {
                            eprintln!("TRACE: L246 element:check_post_pipe_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L247 element:check_post_pipe_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSamelinePipe;
                    continue;
                        }
                    }
                }
                State::Children => {
                    if self.eof() {
                        eprintln!("TRACE: L252 element:children EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L253 element:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::BlankLine { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    state = State::AfterNewline;
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L254 element:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    col = 1;
                    state = State::ChildrenWs;
                    continue;
                        }
                        Some(b'\t') => {
                            eprintln!("TRACE: L255 element:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::NoTabs, span: self.span() });
                    self.scan_to1(b'\n');
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L256 element:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.col() - 1;
                    state = State::CheckChild;
                    continue;
                        }
                    }
                }
                State::AfterNewline => {
                    if self.eof() {
                        eprintln!("TRACE: L259 element:after_newline EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::ElementEnd { span: self.span() });
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L261 element:after_newline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::BlankLine { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L262 element:after_newline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    col = 1;
                    state = State::ChildrenWs;
                    continue;
                        }
                        Some(b'\t') => {
                            eprintln!("TRACE: L263 element:after_newline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::NoTabs, span: self.span() });
                    self.scan_to1(b'\n');
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L264 element:after_newline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.col() - 1;
                    state = State::CheckChild;
                    continue;
                        }
                    }
                }
                State::ChildrenWs => {
                    if self.eof() {
                        eprintln!("TRACE: L268 element:children_ws EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if content_base >= 0 && col >= content_base => {
                            eprintln!("TRACE: L270 element:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::AtContentBase;
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L271 element:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    col += 1;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L272 element:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::BlankLine { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    state = State::AfterNewline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L273 element:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckChild;
                    continue;
                        }
                    }
                }
                State::AtContentBase => {
                    if self.eof() {
                        eprintln!("TRACE: L277 element:at_content_base EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= elem_col => {
                            eprintln!("TRACE: L278 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ElementEnd { span: self.span() });
                    return;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L279 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::BlankLine { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    state = State::AfterNewline;
                    continue;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L280 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildPipe;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L281 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_attr(on_event);
                    state = State::AfterContent;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L282 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_directive(col, on_event);
                    state = State::AfterContent;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L283 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_line_comment(on_event);
                    state = State::AfterContent;
                    continue;
                        }
                        Some(b'@') => {
                            eprintln!("TRACE: L284 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildCheckAt;
                    continue;
                        }
                        Some(b'`') => {
                            eprintln!("TRACE: L285 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildCheckFreeform;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L286 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildApos;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L288 element:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, elem_col, b"", on_event);
                    state = State::AfterContent;
                    continue;
                        }
                    }
                }
                State::CheckChild => {
                    if self.eof() {
                        eprintln!("TRACE: L290 element:check_child EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= elem_col => {
                            eprintln!("TRACE: L291 element:check_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ElementEnd { span: self.span() });
                    return;
                        }
                        _ if content_base >= 0 && col >= content_base => {
                            eprintln!("TRACE: L293 element:check_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::AtContentBase;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L294 element:check_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::ChildDispatch;
                    continue;
                        }
                    }
                }
                State::ChildDispatch => {
                    if self.eof() {
                        eprintln!("TRACE: L298 element:child_dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if content_base < 0 => {
                            eprintln!("TRACE: L300 element:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    content_base = col;
                    state = State::ChildDispatchDo;
                    continue;
                        }
                        _ if col < content_base => {
                            eprintln!("TRACE: L301 element:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Warning { content: std::borrow::Cow::Borrowed(b"Inconsistent indentation"), span: self.span() });
                    content_base = col;
                    state = State::ChildDispatchDo;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L302 element:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::ChildDispatchDo;
                    continue;
                        }
                    }
                }
                State::ChildDispatchDo => {
                    if self.eof() {
                        eprintln!("TRACE: L304 element:child_dispatch_do EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ElementEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'|') => {
                            eprintln!("TRACE: L305 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildPipe;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L306 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_attr(on_event);
                    state = State::AfterContent;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L307 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_directive(col, on_event);
                    state = State::AfterContent;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L308 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_line_comment(on_event);
                    state = State::AfterContent;
                    continue;
                        }
                        Some(b'@') => {
                            eprintln!("TRACE: L309 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildCheckAt;
                    continue;
                        }
                        Some(b'`') => {
                            eprintln!("TRACE: L310 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildCheckFreeform;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L311 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildApos;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L312 element:child_dispatch_do | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::DoProse;
                    continue;
                        }
                    }
