    /// Parse sameline_attr_embedded
    fn parse_sameline_attr_embedded<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L438 ENTER sameline_attr_embedded | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Key, ValueStart,  }
        let mut state = State::Key;
        loop {
            match state {
                State::Key => {
                    if self.eof() {
                        eprintln!("TRACE: L439 sameline_attr_embedded:key EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L440 sameline_attr_embedded:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_attr_reference(on_event);
                    return;
                        }
