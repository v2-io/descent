                            eprintln!("TRACE: L441 sameline_attr_embedded:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_attr_key(on_event);
                    state = State::ValueStart;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L442 sameline_attr_embedded:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_attr_key_quoted(on_event);
                    state = State::ValueStart;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: sameline_attr_embedded:key UNHANDLED | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                            return;
                        }
                    }
                }
                State::ValueStart => {
                    if self.eof() {
                        eprintln!("TRACE: L444 sameline_attr_embedded:value_start EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L445 sameline_attr_embedded:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'\n' | b':' | b'|' | b'}') => {
                            eprintln!("TRACE: L446 sameline_attr_embedded:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L447 sameline_attr_embedded:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_value(1, b'}', on_event);
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse attr_key -> Attr
    fn parse_attr_key<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L450 ENTER attr_key | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L451 attr_key:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::Attr { content: self.term(), span: self.span_from_mark() });
                return;
            }
            match self.peek() {
                Some(b) if Self::is_xlbl_cont(b) => {
                    eprintln!("TRACE: L452 attr_key:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                }
                _ => {
                    eprintln!("TRACE: L453 attr_key:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Attr { content: self.term(), span: self.span_from_mark() });
                    return;
                }
            }
        }
    }

    /// Parse attr_key_quoted -> Attr
    fn parse_attr_key_quoted<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L456 ENTER attr_key_quoted | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L457 attr_key_quoted:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::Attr { content: self.term(), span: self.span_from_mark() });
                return;
            }
                    eprintln!("TRACE: L458 attr_key_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_single_quoted(on_event);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::Attr { content: self.term(), span: self.span_from_mark() });
                    return;
        }
    }

    /// Parse block_reference -> Reference
    fn parse_block_reference<F>(&mut self, on_event: &mut F)
