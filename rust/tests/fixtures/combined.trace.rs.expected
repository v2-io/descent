                }
            }
            Event::Integer { content, span } => {
                StreamEvent::Integer {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Float { content, span } => {
                StreamEvent::Float {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Rational { content, span } => {
                StreamEvent::Rational {
                    content: content.into_owned(),
