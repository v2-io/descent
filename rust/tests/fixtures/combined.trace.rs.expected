                    match self.peek() {
                        Some(b'\'') => {
                            eprintln!("TRACE: L145 parse_element_identity:quoted_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::PostName;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L146 parse_element_identity:quoted_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_quoted_name(on_event);
                    state = State::PostName;
                    continue;
                        }
                    }
                }
                State::PostName => {
                    if self.eof() {
                        eprintln!("TRACE: L148 parse_element_identity:post_name EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b) if b == close => {
                            eprintln!("TRACE: L149 parse_element_identity:post_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        Some(b'[') => {
