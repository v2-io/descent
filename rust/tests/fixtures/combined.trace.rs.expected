    }

    /// Parse value
    fn parse_value<F>(&mut self, space_term: i32, bracket: u8, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L486 ENTER value | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L487 value:start EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
            match self.peek() {
                Some(b'"') => {
                    eprintln!("TRACE: L488 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_double_quoted(on_event);
                    return;
                }
                Some(b'\'') => {
                    eprintln!("TRACE: L489 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_single_quoted(on_event);
                    return;
                }
                Some(b'[') => {
                    eprintln!("TRACE: L490 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_array(on_event);
                    return;
                }
                _ => {
                    eprintln!("TRACE: L491 value:start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.parse_typed_value(space_term, bracket, on_event);
                    return;
                }
            }
        }
    }

    /// Parse value_bracket -> BareValue
    fn parse_value_bracket<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L495 ENTER value_bracket | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'\n', b']', b' ') {
                Some(b']') => {
                    eprintln!("TRACE: L497 value_bracket:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b' ') => {
                    eprintln!("TRACE: L498 value_bracket:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L496 value_bracket:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse double_quoted -> StringValue
    fn parse_double_quoted<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L503 ENTER double_quoted | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'\n', b'"', b'\\') {
                Some(b'"') => {
                    eprintln!("TRACE: L505 double_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\\') => {
                    eprintln!("TRACE: L506 double_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.advance();
                    continue;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L504 double_quoted:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedStringValue, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse single_quoted -> StringValue
    fn parse_single_quoted<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L509 ENTER single_quoted | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'\n', b'\'', b'\\') {
                Some(b'\'') => {
                    eprintln!("TRACE: L511 single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\\') => {
                    eprintln!("TRACE: L512 single_quoted:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.advance();
                    continue;
                }
                Some(b'\n') => {
                    self.advance();
                }
                None => {
                    eprintln!("TRACE: L510 single_quoted:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::StringValue { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedStringValue, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse array -> Array
    fn parse_array<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L517 ENTER array | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::ArrayStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Entry, Items,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    if self.eof() {
                        eprintln!("TRACE: L518 array:entry EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedArray, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L519 array:entry | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Items;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: array:entry UNHANDLED | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                            return;
                        }
                    }
                }
                State::Items => {
                    if self.eof() {
                        eprintln!("TRACE: L520 array:items EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedArray, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b']') => {
                            eprintln!("TRACE: L521 array:items | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::ArrayEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L522 array:items | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L523 array:items | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_value(1, b']', on_event);
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse prose
    fn parse_prose<F>(&mut self, line_col: i32, parent_col: i32, prepend: &'static [u8], on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L532 ENTER prose | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                    if parent_col >= 0 && line_col <= parent_col {
                    return;
                    }
        loop {
            if self.eof() {
                eprintln!("TRACE: L535 prose:content EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
                    eprintln!("TRACE: L536 prose:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text(line_col, parent_col, prepend, on_event);
                    return;
        }
    }

    /// Parse prose_backticks
    fn parse_prose_backticks<F>(&mut self, line_col: i32, parent_col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L540 ENTER prose_backticks | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                    if parent_col >= 0 && line_col <= parent_col {
                    return;
                    }
        loop {
            if self.eof() {
                eprintln!("TRACE: L543 prose_backticks:content EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
                    eprintln!("TRACE: L544 prose_backticks:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text_backticks(line_col, parent_col, on_event);
                    return;
        }
    }

    /// Parse text_backticks
    fn parse_text_backticks<F>(&mut self, line_col: i32, parent_col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L550 ENTER text_backticks | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Entry, Main, CheckPipe, CheckSemi, CheckBang, AfterInline,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    eprintln!("TRACE: L552 text_backticks:entry UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b"`");
                    self.prepend_bytes(b"`");
                    state = State::Main;
                    continue;
                }
                State::Main => {
                    match self.scan_to4(b'\n', b'|', b';', b'!') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L556 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L557 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L558 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L559 text_backticks:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L554 text_backticks:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L562 text_backticks:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L564 text_backticks:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L565 text_backticks:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L568 text_backticks:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L570 text_backticks:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L571 text_backticks:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L573 text_backticks:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L575 text_backticks:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L576 text_backticks:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterInline => {
                    if self.eof() {
                        eprintln!("TRACE: L579 text_backticks:after_inline EOF | term={} pos={}", self.trace_content(), self.pos);
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L580 text_backticks:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L582 text_backticks:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse freeform -> Freeform
    fn parse_freeform<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L592 ENTER freeform | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::FreeformStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Lang, LineStart, Content, Line, MaybeEnd1, MaybeEnd2,  }
        let mut state = State::Lang;
        loop {
            match state {
                State::Lang => {
                    if self.eof() {
                        eprintln!("TRACE: L593 freeform:lang EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L594 freeform:lang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::LineStart;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L595 freeform:lang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    self.scan_to1(b'\n');
                    self.advance();
                    state = State::LineStart;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L596 freeform:lang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::LineStart;
                    continue;
                        }
                    }
                }
                State::LineStart => {
                    if self.eof() {
                        eprintln!("TRACE: L599 freeform:line_start EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L600 freeform:line_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L601 freeform:line_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L604 freeform:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L605 freeform:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'`') => {
                            eprintln!("TRACE: L606 freeform:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::MaybeEnd1;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L607 freeform:content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::Line => {
                    eprintln!("TRACE: L610 freeform:line UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.scan_to1(b'\n');
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::LineStart;
                    continue;
                }
                State::MaybeEnd1 => {
                    if self.eof() {
                        eprintln!("TRACE: L613 freeform:maybe_end1 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L614 freeform:maybe_end1 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::MaybeEnd2;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L615 freeform:maybe_end1 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Line;
                    continue;
                        }
                    }
                }
                State::MaybeEnd2 => {
                    if self.eof() {
                        eprintln!("TRACE: L617 freeform:maybe_end2 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedFreeform, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L618 freeform:maybe_end2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::FreeformEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L619 freeform:maybe_end2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Line;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse text
    fn parse_text<F>(&mut self, line_col: i32, parent_col: i32, prepend: &'static [u8], on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L627 ENTER text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Entry, Main, CheckPipe, CheckSemi, CheckBang, AfterInline,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    eprintln!("TRACE: L629 text:entry UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(prepend);
                    state = State::Main;
                    continue;
                }
                State::Main => {
                    match self.scan_to4(b'\n', b'|', b';', b'!') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L633 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L634 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L635 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L636 text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L631 text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L639 text:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L641 text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L642 text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L645 text:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L647 text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L648 text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L650 text:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L652 text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L653 text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterInline => {
                    if self.eof() {
                        eprintln!("TRACE: L656 text:after_inline EOF | term={} pos={}", self.trace_content(), self.pos);
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L657 text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L659 text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse sameline_text
    fn parse_sameline_text<F>(&mut self, elem_col: i32, prepend: &'static [u8], on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L667 ENTER sameline_text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Entry, Main, CheckPipe, CheckPipeElemCol, CheckSemi, CheckBang, AfterInline,  }
        let mut state = State::Entry;
        loop {
            match state {
                State::Entry => {
                    eprintln!("TRACE: L669 sameline_text:entry UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(prepend);
                    state = State::Main;
                    continue;
                }
                State::Main => {
                    match self.scan_to4(b'\n', b'|', b';', b'!') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L673 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L674 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L675 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L676 sameline_text:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L671 sameline_text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L679 sameline_text:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L681 sameline_text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) || b == b'\'' || b == b'[' || b == b'.' || b == b'?' || b == b'!' || b == b'*' || b == b'+' => {
                            eprintln!("TRACE: L682 sameline_text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckPipeElemCol;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L683 sameline_text:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckPipeElemCol => {
                    if self.eof() {
                        eprintln!("TRACE: L686 sameline_text:check_pipe_elem_col EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        _ if self.col() - 1 <= elem_col => {
                            eprintln!("TRACE: L687 sameline_text:check_pipe_elem_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L688 sameline_text:check_pipe_elem_col | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.parse_element(self.col() - 1, elem_col, on_event);
                    state = State::AfterInline;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L690 sameline_text:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L692 sameline_text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L693 sameline_text:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.parse_line_comment_content(on_event);
                    return;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L695 sameline_text:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L697 sameline_text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(-1);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    state = State::AfterInline;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L698 sameline_text:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterInline => {
                    if self.eof() {
                        eprintln!("TRACE: L701 sameline_text:after_inline EOF | term={} pos={}", self.trace_content(), self.pos);
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L702 sameline_text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L704 sameline_text:after_inline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse line_comment -> Comment
    fn parse_line_comment<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L721 ENTER line_comment | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::CommentStart { span: start_span.clone() });
        let comment_col: i32 = self.col() - 1;
        let mut content_base: i32 = -1;
        let mut col: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Check, FirstLine, Children, ChildrenWs, CheckContinuation, AtContentBase, ContContent, ContLine,  }
        let mut state = State::Check;
        loop {
            match state {
                State::Check => {
                    if self.eof() {
                        eprintln!("TRACE: L722 line_comment:check EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L723 line_comment:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_comment_text_braced(on_event);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L724 line_comment:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::FirstLine;
                    continue;
                        }
                    }
                }
                State::FirstLine => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L729 line_comment:first_line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L727 line_comment:first_line EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Children => {
                    if self.eof() {
                        eprintln!("TRACE: L734 line_comment:children EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L736 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L737 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    col = 1;
                    state = State::ChildrenWs;
                    continue;
                        }
                        Some(b'\t') => {
                            eprintln!("TRACE: L738 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L739 line_comment:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::ChildrenWs => {
                    if self.eof() {
                        eprintln!("TRACE: L742 line_comment:children_ws EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if content_base >= 0 && col >= content_base => {
                            eprintln!("TRACE: L744 line_comment:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::AtContentBase;
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L745 line_comment:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    col += 1;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L746 line_comment:children_ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckContinuation;
                    continue;
                        }
                    }
                }
                State::CheckContinuation => {
                    if self.eof() {
                        eprintln!("TRACE: L749 line_comment:check_continuation EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= comment_col => {
                            eprintln!("TRACE: L750 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        Some(b'|' | b':' | b'!' | b';') => {
                            eprintln!("TRACE: L751 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ if content_base < 0 => {
                            eprintln!("TRACE: L754 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    content_base = col;
                    self.mark();
                    state = State::ContLine;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L756 line_comment:check_continuation | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Warning { content: std::borrow::Cow::Borrowed(b"Inconsistent indentation"), span: self.span() });
                    content_base = col;
                    self.mark();
                    state = State::ContLine;
                    continue;
                        }
                    }
                }
                State::AtContentBase => {
                    if self.eof() {
                        eprintln!("TRACE: L759 line_comment:at_content_base EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'|' | b':' | b'!' | b';') => {
                            eprintln!("TRACE: L760 line_comment:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L761 line_comment:at_content_base | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::ContContent;
                    continue;
                        }
                    }
                }
                State::ContContent => {
                    if self.eof() {
                        eprintln!("TRACE: L764 line_comment:cont_content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::CommentEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ') => {
                            eprintln!("TRACE: L765 line_comment:cont_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L766 line_comment:cont_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::ContLine;
                    continue;
                        }
                    }
                }
                State::ContLine => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L770 line_comment:cont_line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L768 line_comment:cont_line EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
            }
        }
    }

    /// Parse line_comment_content -> Comment
    fn parse_line_comment_content<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L776 ENTER line_comment_content | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::CommentStart { span: start_span.clone() });
                    self.mark();
                    self.scan_to1(b'\n');
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
        on_event(Event::CommentEnd { span: self.span() });
    }

    /// Parse skip_brace_balanced
    fn parse_skip_brace_balanced<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L782 ENTER skip_brace_balanced | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let mut depth: i32 = 1;
        #[derive(Clone, Copy)]
        enum State { Main, Check,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    match self.scan_to3(b'\n', b'{', b'}') {
                        Some(b'{') => {
                            eprintln!("TRACE: L784 skip_brace_balanced:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    depth += 1;
                    continue;
                        }
                        Some(b'}') => {
                            eprintln!("TRACE: L785 skip_brace_balanced:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    depth -= 1;
                    state = State::Check;
                    continue;
                        }
                        Some(b'\n') => {
                            self.advance();
                        }
                        None => {
                            eprintln!("TRACE: L783 skip_brace_balanced:main EOF | term={} pos={}", self.trace_content(), self.pos);
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Check => {
                    if self.eof() {
                        eprintln!("TRACE: L788 skip_brace_balanced:check EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        _ if depth == 0 => {
                            eprintln!("TRACE: L789 skip_brace_balanced:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L790 skip_brace_balanced:check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse brace_comment -> Comment
    fn parse_brace_comment<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L795 ENTER brace_comment | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::CommentStart { span: start_span.clone() });
        loop {
            if self.eof() {
                eprintln!("TRACE: L796 brace_comment:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::CommentEnd { span: self.span() });
                return;
            }
                    eprintln!("TRACE: L797 brace_comment:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_comment_text_braced(on_event);
                    on_event(Event::CommentEnd { span: self.span() });
                    return;
        }
    }

    /// Parse comment_text_braced
    fn parse_comment_text_braced<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L801 ENTER comment_text_braced | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                    self.mark();
        loop {
            if self.eof() {
                eprintln!("TRACE: L802 comment_text_braced:main EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
                    eprintln!("TRACE: L803 comment_text_braced:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    return;
        }
    }

    /// Parse embedded -> Embedded
    fn parse_embedded<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L811 ENTER embedded | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::EmbeddedStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Identity, PostIdentity, PreContent,  }
        let mut state = State::Identity;
        loop {
            match state {
                State::Identity => {
                    eprintln!("TRACE: L814 embedded:identity UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.parse_parse_element_identity(b'}', on_event);
                    state = State::PostIdentity;
                    continue;
                }
                State::PostIdentity => {
                    if self.eof() {
                        eprintln!("TRACE: L816 embedded:post_identity EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::EmbeddedEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L817 embedded:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L818 embedded:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::PreContent;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L819 embedded:post_identity | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_embed_content(on_event);
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::PreContent => {
                    if self.eof() {
                        eprintln!("TRACE: L821 embedded:pre_content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::EmbeddedEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L822 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L823 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L824 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_attr_embedded(on_event);
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L825 embedded:pre_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_embed_content(on_event);
                    on_event(Event::EmbeddedEnd { span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse embed_content -> Text
    fn parse_embed_content<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L831 ENTER embed_content | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, CheckPipe, CheckSemi, CheckBang,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    match self.scan_to6(b'}', b'|', b';', b'!', b'"', b'\'') {
                        Some(b'}') => {
                            eprintln!("TRACE: L833 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        Some(b'|') => {
                            eprintln!("TRACE: L834 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::CheckPipe;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L835 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::CheckSemi;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L836 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::CheckBang;
                    continue;
                        }
                        Some(b'"') => {
                            eprintln!("TRACE: L837 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_double_quoted(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L838 embed_content:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_single_quoted(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L832 embed_content:main EOF | term={} pos={}", self.trace_content(), self.pos);
                            on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                            on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L841 embed_content:check_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                        on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L843 embed_content:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_embedded(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L844 embed_content:check_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b"|");
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckSemi => {
                    if self.eof() {
                        eprintln!("TRACE: L846 embed_content:check_semi EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                        on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L848 embed_content:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_brace_comment(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L849 embed_content:check_semi | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b";");
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::CheckBang => {
                    if self.eof() {
                        eprintln!("TRACE: L851 embed_content:check_bang EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                        on_event(Event::Error { code: ParseErrorCode::UnclosedText, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L853 embed_content:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    self.mark();
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L854 embed_content:check_bang | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.prepend_bytes(b"!");
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse block_directive -> Directive
    fn parse_block_directive<F>(&mut self, line_col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L862 ENTER block_directive | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::DirectiveStart { span: start_span.clone() });
        let mut col: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Dispatch, RawKind, RawColon, RawEol, RawContent, RawCheck, RawLine, AfterName, Condition, Children, CheckChild, ChildDispatch, ChildApos, ChildPipe,  }
        let mut state = State::Dispatch;
        loop {
            match state {
                State::Dispatch => {
                    if self.eof() {
                        eprintln!("TRACE: L863 block_directive:dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b':') => {
                            eprintln!("TRACE: L864 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RawKind;
                    continue;
                        }
                        Some(b'{') => {
                            eprintln!("TRACE: L865 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_directive(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L866 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    state = State::AfterName;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L867 block_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawKind => {
                    if self.eof() {
                        eprintln!("TRACE: L870 block_directive:raw_kind EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L871 block_directive:raw_kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    on_event(Event::Raw { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    state = State::RawColon;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L872 block_directive:raw_kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawColon => {
                    if self.eof() {
                        eprintln!("TRACE: L874 block_directive:raw_colon EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b':') => {
                            eprintln!("TRACE: L875 block_directive:raw_colon | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RawEol;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L876 block_directive:raw_colon | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawEol => {
                    match self.scan_to3(b'\n', b' ', b'\t') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L879 block_directive:raw_eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RawContent;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L880 block_directive:raw_eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L878 block_directive:raw_eol EOF | term={} pos={}", self.trace_content(), self.pos);
                            on_event(Event::DirectiveEnd { span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::RawContent => {
                    if self.eof() {
                        eprintln!("TRACE: L884 block_directive:raw_content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L885 block_directive:raw_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L886 block_directive:raw_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.parse_count_indent(on_event);
                    state = State::RawCheck;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L887 block_directive:raw_content | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RawCheck => {
                    if self.eof() {
                        eprintln!("TRACE: L889 block_directive:raw_check EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= line_col => {
                            eprintln!("TRACE: L890 block_directive:raw_check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L891 block_directive:raw_check | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    state = State::RawLine;
                    continue;
                        }
                    }
                }
                State::RawLine => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L895 block_directive:raw_line | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::RawContent { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    state = State::RawContent;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L893 block_directive:raw_line EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::RawContent { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::AfterName => {
                    if self.eof() {
                        eprintln!("TRACE: L899 block_directive:after_name EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L900 block_directive:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L901 block_directive:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Condition;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L902 block_directive:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::Condition => {
                    if self.eof() {
                        eprintln!("TRACE: L904 block_directive:condition EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L905 block_directive:condition | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L906 block_directive:condition | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.mark();
                    self.parse_directive_args(on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::Children => {
                    if self.eof() {
                        eprintln!("TRACE: L909 block_directive:children EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L910 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ') => {
                            eprintln!("TRACE: L911 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.parse_count_indent(on_event);
                    state = State::CheckChild;
                    continue;
                        }
                        Some(b'\t') => {
                            eprintln!("TRACE: L912 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Error { code: ParseErrorCode::NoTabs, span: self.span() });
                    self.scan_to1(b'\n');
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L913 block_directive:children | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    col = self.col() - 1;
                    state = State::CheckChild;
                    continue;
                        }
                    }
                }
                State::CheckChild => {
                    if self.eof() {
                        eprintln!("TRACE: L915 block_directive:check_child EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if col <= line_col => {
                            eprintln!("TRACE: L916 block_directive:check_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L917 block_directive:check_child | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::ChildDispatch;
                    continue;
                        }
                    }
                }
                State::ChildDispatch => {
                    if self.eof() {
                        eprintln!("TRACE: L919 block_directive:child_dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'|') => {
                            eprintln!("TRACE: L920 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildPipe;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L921 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_attr(on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L922 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_block_directive(col, on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L923 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_line_comment(on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L924 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::ChildApos;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L925 block_directive:child_dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, line_col, b"", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::ChildApos => {
                    if self.eof() {
                        eprintln!("TRACE: L928 block_directive:child_apos EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'|') => {
                            eprintln!("TRACE: L929 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b"|", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b';') => {
                            eprintln!("TRACE: L930 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b";", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b':') => {
                            eprintln!("TRACE: L931 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b":", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'!') => {
                            eprintln!("TRACE: L932 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b"!", on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L933 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_prose(col, line_col, b"'", on_event);
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L934 block_directive:child_apos | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, line_col, b"'", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
                State::ChildPipe => {
                    if self.eof() {
                        eprintln!("TRACE: L936 block_directive:child_pipe EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'{') => {
                            eprintln!("TRACE: L937 block_directive:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_embedded(on_event);
                    state = State::Children;
                    continue;
                        }
                        Some(b) if Self::is_xlbl_start(b) || b == b'\'' || b == b'[' || b == b'.' || b == b'?' || b == b'!' || b == b'*' || b == b'+' => {
                            eprintln!("TRACE: L938 block_directive:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_element(col, line_col, on_event);
                    state = State::Children;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L939 block_directive:child_pipe | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_prose(col, line_col, b"|", on_event);
                    state = State::Children;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse directive_args -> Text
    fn parse_directive_args<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L943 ENTER directive_args | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
                    self.scan_to1(b'\n');
                    self.set_term(0);
        on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
    }

    /// Parse sameline_directive
    fn parse_sameline_directive<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L948 ENTER sameline_directive | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L949 sameline_directive:dispatch EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
            match self.peek() {
                Some(b'{') => {
                    eprintln!("TRACE: L950 sameline_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_interpolation(on_event);
                    return;
                }
                Some(b':') => {
                    eprintln!("TRACE: L951 sameline_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_sameline_raw(on_event);
                    return;
                }
                _ => {
                    eprintln!("TRACE: L952 sameline_directive:dispatch | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_sameline_dir_body(on_event);
                    return;
                }
            }
        }
    }

    /// Parse interpolation -> Interpolation
    fn parse_interpolation<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L956 ENTER interpolation | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        #[derive(Clone, Copy)]
        enum State { Main, Closing,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    match self.scan_to2(b'\n', b'}') {
                        Some(b'}') => {
                            eprintln!("TRACE: L959 interpolation:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    state = State::Closing;
                    continue;
                        }
                        Some(b'\n') => {
                            self.advance();
                        }
                        None => {
                            eprintln!("TRACE: L957 interpolation:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedInterpolation, span: self.span() });
                    return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Closing => {
                    if self.eof() {
                        eprintln!("TRACE: L962 interpolation:closing EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L963 interpolation:closing | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L964 interpolation:closing | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Interpolation { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedInterpolation, span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse sameline_raw -> Directive
    fn parse_sameline_raw<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L970 ENTER sameline_raw | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::DirectiveStart { span: start_span.clone() });
        let mut depth: i32 = 0;
        #[derive(Clone, Copy)]
        enum State { Kind, Content, Scan, CheckClose,  }
        let mut state = State::Kind;
        loop {
            match state {
                State::Kind => {
                    if self.eof() {
                        eprintln!("TRACE: L971 sameline_raw:kind EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b':') => {
                            eprintln!("TRACE: L972 sameline_raw:kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L973 sameline_raw:kind | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    continue;
                        }
                    }
                }
                State::Content => {
                    eprintln!("TRACE: L976 sameline_raw:content UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.mark();
                    state = State::Scan;
                    continue;
                }
                State::Scan => {
                    match self.scan_to3(b'\n', b'{', b'}') {
                        Some(b'{') => {
                            eprintln!("TRACE: L979 sameline_raw:scan | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    depth += 1;
                    continue;
                        }
                        Some(b'}') => {
                            eprintln!("TRACE: L980 sameline_raw:scan | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckClose;
                    continue;
                        }
                        Some(b'\n') => {
                            self.advance();
                        }
                        None => {
                            eprintln!("TRACE: L978 sameline_raw:scan EOF | term={} pos={}", self.trace_content(), self.pos);
                            on_event(Event::DirectiveEnd { span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::CheckClose => {
                    if self.eof() {
                        eprintln!("TRACE: L983 sameline_raw:check_close EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if depth > 0 => {
                            eprintln!("TRACE: L984 sameline_raw:check_close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    depth -= 1;
                    state = State::Scan;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L985 sameline_raw:check_close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    on_event(Event::RawContent { content: self.term(), span: self.span_from_mark() });
                    self.advance();
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse sameline_dir_body -> Directive
    fn parse_sameline_dir_body<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L989 ENTER sameline_dir_body | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::DirectiveStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Name, AfterName, Args,  }
        let mut state = State::Name;
        loop {
            match state {
                State::Name => {
                    if self.eof() {
                        eprintln!("TRACE: L990 sameline_dir_body:name EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L991 sameline_dir_body:name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_name(on_event);
                    state = State::AfterName;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L992 sameline_dir_body:name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::AfterName => {
                    if self.eof() {
                        eprintln!("TRACE: L994 sameline_dir_body:after_name EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L995 sameline_dir_body:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L996 sameline_dir_body:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Args;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L997 sameline_dir_body:after_name | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Args => {
                    if self.eof() {
                        eprintln!("TRACE: L999 sameline_dir_body:args EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::DirectiveEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'}') => {
                            eprintln!("TRACE: L1000 sameline_dir_body:args | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L1001 sameline_dir_body:args | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_skip_brace_balanced(on_event);
                    on_event(Event::DirectiveEnd { span: self.span() });
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse emit_bare_value
    fn parse_emit_bare_value<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L1056 ENTER emit_bare_value | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L1057 emit_bare_value:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
            }
                    eprintln!("TRACE: L1059 emit_bare_value:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BareValue { content: self.term(), span: self.span_from_mark() });
                    return;
        }
    }

    /// Parse typed_value
    fn parse_typed_value<F>(&mut self, space_term: i32, bracket: u8, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L1068 ENTER typed_value | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
