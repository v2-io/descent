                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"id"), span: self.span() });
                    self.parse_value_bracket(on_event);
                    state = State::BracketClose;
                    continue;
                        }
                    }
                }
                State::BracketClose => {
                    if self.eof() {
                        eprintln!("TRACE: L166 parse_element_identity:bracket_close EOF | term={} pos={}", self.trace_content(), self.pos);
