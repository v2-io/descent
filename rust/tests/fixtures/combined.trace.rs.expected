    /// Parse suffix
    fn parse_suffix<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L400 ENTER suffix | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        loop {
            if self.eof() {
                eprintln!("TRACE: L401 suffix:main EOF | term={} pos={}", self.trace_content(), self.pos);
                return;
            }
            match self.peek() {
                Some(b'?') => {
                    eprintln!("TRACE: L402 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"?"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                Some(b'!') => {
                    eprintln!("TRACE: L403 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"!"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                Some(b'*') => {
                    eprintln!("TRACE: L404 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                Some(b'+') => {
                    eprintln!("TRACE: L405 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Attr { content: std::borrow::Cow::Borrowed(b"+"), span: self.span() });
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    self.advance();
                    return;
                }
                _ => {
                    eprintln!("TRACE: L406 suffix:main | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                }
            }
        }
    }

    /// Parse block_attr
    fn parse_block_attr<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L409 ENTER block_attr | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Key, ValueStart, PostValue,  }
        let mut state = State::Key;
        loop {
            match state {
                State::Key => {
                    if self.eof() {
                        eprintln!("TRACE: L410 block_attr:key EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'[') => {
                            eprintln!("TRACE: L411 block_attr:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_attr_reference(on_event);
                    return;
                        }
                        Some(b) if Self::is_xlbl_start(b) => {
                            eprintln!("TRACE: L412 block_attr:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_attr_key(on_event);
                    state = State::ValueStart;
                    continue;
                        }
                        Some(b'\'') => {
                            eprintln!("TRACE: L413 block_attr:key | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_attr_key_quoted(on_event);
                    state = State::ValueStart;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: block_attr:key UNHANDLED | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
                            return;
                        }
                    }
                }
                State::ValueStart => {
                    if self.eof() {
                        eprintln!("TRACE: L415 block_attr:value_start EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L416 block_attr:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L417 block_attr:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BoolTrue { content: std::borrow::Cow::Borrowed(b""), span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L418 block_attr:value_start | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_value(0, b'\0', on_event);
                    state = State::PostValue;
                    continue;
                        }
                    }
                }
                State::PostValue => {
                    if self.eof() {
                        eprintln!("TRACE: L421 block_attr:post_value EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b';') => {
                            eprintln!("TRACE: L422 block_attr:post_value | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_line_comment_content(on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L423 block_attr:post_value | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                    }
                }
            }
        }
    }

