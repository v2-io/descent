    /// Parse heading -> Heading
    fn parse_heading<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L70 ENTER heading | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::HeadingStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Hashes, Content, Trailing, CloseHash,  }
        let mut state = State::Hashes;
        loop {
            match state {
                State::Hashes => {
                    if self.eof() {
                        eprintln!("TRACE: L71 heading:hashes EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::HeadingEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'#') => {
                            eprintln!("TRACE: L72 heading:hashes.hash | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L73 heading:hashes.space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L74 heading:hashes.empty | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L75 heading:hashes.not_head | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L77 heading:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::HeadingEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L78 heading:content.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L79 heading:content.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L80 heading:content.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_inline(on_event);
                    state = State::Trailing;
                    continue;
                        }
                    }
                }
                State::Trailing => {
                    if self.eof() {
                        eprintln!("TRACE: L83 heading:trailing EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::HeadingEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L84 heading:trailing.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::HeadingEnd { span: self.span() });
                    return;
                        }
                        Some(b'#') => {
                            eprintln!("TRACE: L85 heading:trailing.trail | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CloseHash;
                    continue;
                        }
                        _ => {
