                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'*') => {
                            eprintln!("TRACE: L376 strong:content.star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckStar;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L377 strong:content.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::StrongEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L378 strong:content.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_emph_text(on_event);
                    continue;
                        }
                    }
                }
                State::CheckStar => {
                    if self.eof() {
                        eprintln!("TRACE: L381 strong:check_star EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                            eprintln!("TRACE: L382 strong:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                            eprintln!("TRACE: L383 strong:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                            eprintln!("TRACE: L384 strong:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                            eprintln!("TRACE: L385 strong:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
