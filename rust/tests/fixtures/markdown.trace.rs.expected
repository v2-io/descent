    /// Parse strong -> Strong
    fn parse_strong<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L373 ENTER strong | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::StrongStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckStar, RightFlankSingle, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L374 strong:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::StrongEnd { span: self.span() });
                        return;
