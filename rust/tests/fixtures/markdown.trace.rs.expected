    /// Parse strikethrough -> Strikethrough
    fn parse_strikethrough<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L480 ENTER strikethrough | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::StrikethroughStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckTilde, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L481 strikethrough:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L482 strikethrough:content.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'~') => {
                            eprintln!("TRACE: L483 strikethrough:content.tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckTilde;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L484 strikethrough:content.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::StrikethroughEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L485 strikethrough:content.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_strike_text(on_event);
                    continue;
                        }
                    }
                }
                State::CheckTilde => {
                    if self.eof() {
                        eprintln!("TRACE: L487 strikethrough:check_tilde EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                            eprintln!("TRACE: L488 strikethrough:check_tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                            eprintln!("TRACE: L489 strikethrough:check_tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                            eprintln!("TRACE: L490 strikethrough:check_tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                            eprintln!("TRACE: L491 strikethrough:check_tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'~') => {
                            eprintln!("TRACE: L493 strikethrough:check_tilde.double | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L494 strikethrough:check_tilde.single | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::RightFlankDouble => {
                    eprintln!("TRACE: L497 strikethrough:right_flank_double.close UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::StrikethroughEnd { span: self.span() });
                    return;
                }
                State::NotRightFlanking => {
                    if self.eof() {
                        eprintln!("TRACE: L499 strikethrough:not_right_flanking EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'~') => {
                            eprintln!("TRACE: L501 strikethrough:not_right_flanking.double | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRfDouble;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L502 strikethrough:not_right_flanking.literal | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L503 strikethrough:not_right_flanking.nested | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_strikethrough(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::NotRfDouble => {
                    if self.eof() {
                        eprintln!("TRACE: L505 strikethrough:not_rf_double EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::StrikethroughEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L506 strikethrough:not_rf_double.literal | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~~"), span: self.span() });
                    state = State::Content;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L507 strikethrough:not_rf_double.nested | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_strikethrough(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse text -> Text
    fn parse_text<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L514 ENTER text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to5(b'`', b'*', b'_', b'~', b'\n') {
                Some(b'`') => {
                    eprintln!("TRACE: L516 text:main.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'*') => {
                    eprintln!("TRACE: L517 text:main.star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'_') => {
                    eprintln!("TRACE: L518 text:main.under | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'~') => {
                    eprintln!("TRACE: L519 text:main.tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    eprintln!("TRACE: L520 text:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    eprintln!("TRACE: L515 text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse emph_text -> Text
    fn parse_emph_text<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L524 ENTER emph_text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'`', b'*', b'\n') {
                Some(b'`') => {
                    eprintln!("TRACE: L526 emph_text:main.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'*') => {
                    eprintln!("TRACE: L527 emph_text:main.star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    eprintln!("TRACE: L528 emph_text:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    eprintln!("TRACE: L525 emph_text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse emph_text_under -> Text
    fn parse_emph_text_under<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L532 ENTER emph_text_under | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'`', b'_', b'\n') {
                Some(b'`') => {
                    eprintln!("TRACE: L534 emph_text_under:main.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'_') => {
                    eprintln!("TRACE: L535 emph_text_under:main.under | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    eprintln!("TRACE: L536 emph_text_under:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    eprintln!("TRACE: L533 emph_text_under:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse strike_text -> Text
    fn parse_strike_text<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L540 ENTER strike_text | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to3(b'`', b'~', b'\n') {
                Some(b'`') => {
                    eprintln!("TRACE: L542 strike_text:main.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'~') => {
                    eprintln!("TRACE: L543 strike_text:main.tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    eprintln!("TRACE: L544 strike_text:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    eprintln!("TRACE: L541 strike_text:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Text { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }
}

// ============================================================================
// Streaming Parser (multi-chunk support)
// ============================================================================
/// Result of parsing a chunk in streaming mode.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParseResult {
    /// Parsing completed successfully (EOF reached).
    Complete,
    /// More data needed - provide another chunk.
    NeedMoreData,
}

/// Event with owned content for streaming across chunk boundaries.
#[derive(Debug, Clone, PartialEq)]
pub enum StreamEvent {
    HeadingStart { span: Range<usize> },
    HeadingEnd { span: Range<usize> },
    ParagraphStart { span: Range<usize> },
    ParagraphEnd { span: Range<usize> },
    CodeBlockStart { span: Range<usize> },
    CodeBlockEnd { span: Range<usize> },
    BlockquoteStart { span: Range<usize> },
    BlockquoteEnd { span: Range<usize> },
    ListItemStart { span: Range<usize> },
    ListItemEnd { span: Range<usize> },
    ThematicBreakStart { span: Range<usize> },
    ThematicBreakEnd { span: Range<usize> },
    EmphasisStart { span: Range<usize> },
    EmphasisEnd { span: Range<usize> },
    StrongStart { span: Range<usize> },
    StrongEnd { span: Range<usize> },
    StrikethroughStart { span: Range<usize> },
    StrikethroughEnd { span: Range<usize> },
    Text { content: Vec<u8>, span: Range<usize> },
    Code { content: Vec<u8>, span: Range<usize> },
    Error { code: ParseErrorCode, span: Range<usize> },
}
impl StreamEvent {
    /// Convert from borrowed Event to owned StreamEvent.
    fn from_event(event: Event<'_>, offset: usize) -> Self {
        match event {
            Event::HeadingStart { span } => {
                StreamEvent::HeadingStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::HeadingEnd { span } => {
                StreamEvent::HeadingEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ParagraphStart { span } => {
                StreamEvent::ParagraphStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ParagraphEnd { span } => {
                StreamEvent::ParagraphEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::CodeBlockStart { span } => {
                StreamEvent::CodeBlockStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::CodeBlockEnd { span } => {
                StreamEvent::CodeBlockEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::BlockquoteStart { span } => {
                StreamEvent::BlockquoteStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::BlockquoteEnd { span } => {
                StreamEvent::BlockquoteEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ListItemStart { span } => {
                StreamEvent::ListItemStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ListItemEnd { span } => {
                StreamEvent::ListItemEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ThematicBreakStart { span } => {
                StreamEvent::ThematicBreakStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::ThematicBreakEnd { span } => {
                StreamEvent::ThematicBreakEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::EmphasisStart { span } => {
                StreamEvent::EmphasisStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::EmphasisEnd { span } => {
                StreamEvent::EmphasisEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrongStart { span } => {
                StreamEvent::StrongStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrongEnd { span } => {
                StreamEvent::StrongEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrikethroughStart { span } => {
                StreamEvent::StrikethroughStart { span: (span.start + offset)..(span.end + offset) }
            }
            Event::StrikethroughEnd { span } => {
                StreamEvent::StrikethroughEnd { span: (span.start + offset)..(span.end + offset) }
            }
            Event::Text { content, span } => {
                StreamEvent::Text {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Code { content, span } => {
                StreamEvent::Code {
                    content: content.into_owned(),
                    span: (span.start + offset)..(span.end + offset),
                }
            }
            Event::Error { code, span } => {
                StreamEvent::Error { code, span: (span.start + offset)..(span.end + offset) }
            }
        }
    }
}

/// Streaming parser for chunk-by-chunk input.
///
/// Wraps the single-buffer `Parser` to handle input arriving in chunks.
/// Buffers incomplete content across chunk boundaries.
///
/// # Example
///
/// ```ignore
/// let mut parser = StreamingParser::new();
/// loop {
///     match parser.parse(chunk, |event| handle(event)) {
///         ParseResult::Complete => break,
///         ParseResult::NeedMoreData => {
///             chunk = get_next_chunk();
///             if chunk.is_empty() {
///                 parser.finish(|event| handle(event));
///                 break;
///             }

///         }

///     }

/// }

/// ```

pub struct StreamingParser {
    /// Buffer for incomplete content at chunk boundaries.
    buffer: Vec<u8>,
    /// Maximum buffer size before error (default 4KB).
    max_buffer: usize,
    /// Global byte offset for span calculation.
    global_offset: usize,
    /// Line number (persists across chunks).
    line: u32,
    /// Column number (persists across chunks).
    column: u32,
}
impl Default for StreamingParser {
    fn default() -> Self {
        Self::new()
    }
}
impl StreamingParser {
    /// Create a new streaming parser with default settings.
    pub fn new() -> Self {
        Self::with_max_buffer(4096)
    }

    /// Create a streaming parser with custom buffer limit.
    pub fn with_max_buffer(max_buffer: usize) -> Self {
        Self {
            buffer: Vec::new(),
            max_buffer,
            global_offset: 0,
            line: 1,
            column: 1,
        }
    }

    /// Parse a chunk of input, emitting events for complete lines.
    ///
    /// Uses line-oriented streaming: only parses complete lines (ending in `\n`).
    /// Incomplete lines are buffered until more data arrives.
    ///
    /// Returns `NeedMoreData` if the chunk ends mid-line.
    /// Call `finish()` after the last chunk to handle any remaining content.
    pub fn parse<F>(&mut self, chunk: &[u8], mut on_event: F) -> ParseResult
    where
        F: FnMut(StreamEvent),
    {
        // Append new chunk to buffer
        self.buffer.extend_from_slice(chunk);
        if self.buffer.is_empty() {
            return ParseResult::NeedMoreData;
        }

        // Check buffer size limit
        if self.buffer.len() > self.max_buffer {
            on_event(StreamEvent::Error {
                code: ParseErrorCode::UnexpectedEof, // Buffer overflow
                span: self.global_offset..self.global_offset,
            });
            self.buffer.clear();
            return ParseResult::Complete;
        }

        // Find last complete line (ending with \n)
        let last_newline = self.buffer.iter().rposition(|&b| b == b'\n');
        let parse_end = match last_newline {
            Some(pos) => pos + 1, // Include the newline
            None => return ParseResult::NeedMoreData, // No complete line yet
        };
        // Extract complete lines to parse
        let to_parse: Vec<u8> = self.buffer.drain(..parse_end).collect();
        let offset = self.global_offset;
        // Parse complete lines
        let mut inner = Parser::new(&to_parse);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
        // Update state
        self.global_offset += to_parse.len();
        for &b in &to_parse {
            if b == b'\n' {
                self.line += 1;
                self.column = 1;
            } else {
                self.column += 1;
            }
        }
        ParseResult::NeedMoreData
    }

    /// Signal end of input and handle any remaining buffered content.
    ///
    /// This triggers EOF handling for any incomplete constructs.
    pub fn finish<F>(mut self, mut on_event: F)
    where
        F: FnMut(StreamEvent),
    {
        if self.buffer.is_empty() {
            return;
        }

        // Parse remaining buffer - this will hit EOF
        let input = std::mem::take(&mut self.buffer);
        let offset = self.global_offset;
        let mut inner = Parser::new(&input);
        inner.line = self.line;
        inner.column = self.column;
        inner.parse(|event| {
            on_event(StreamEvent::from_event(event, offset));
        });
    }

    /// Returns the current global byte offset.
    pub fn offset(&self) -> usize {
        self.global_offset
    }

    /// Returns the current line number.
    pub fn line(&self) -> u32 {
        self.line
    }

    /// Returns the current column number.
    pub fn column(&self) -> u32 {
        self.column
    }
}

