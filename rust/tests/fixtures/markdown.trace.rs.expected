                    continue;
                        }
                        _ if self.prev() == 0 => {
                            eprintln!("TRACE: L425 emphasis_under:check_under | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'_') => {
