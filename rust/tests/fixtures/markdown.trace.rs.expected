        let start_span = self.span();
        on_event(Event::ParagraphStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Main, Check,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        eprintln!("TRACE: L99 paragraph:main EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ParagraphEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L100 paragraph:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Check;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L101 paragraph:main.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_inline(on_event);
                    continue;
                        }
                    }
                }
                State::Check => {
                    if self.eof() {
                        eprintln!("TRACE: L104 paragraph:check EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ParagraphEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L105 paragraph:check.blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'#') => {
                            eprintln!("TRACE: L106 paragraph:check.heading | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'`') => {
                            eprintln!("TRACE: L107 paragraph:check.fence | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'>') => {
                            eprintln!("TRACE: L108 paragraph:check.quote | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'-') => {
                            eprintln!("TRACE: L109 paragraph:check.dash | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        Some(b'*') => {
                            eprintln!("TRACE: L110 paragraph:check.star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ParagraphEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L111 paragraph:check.cont | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_inline(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse maybe_fence
    fn parse_maybe_fence<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L117 ENTER maybe_fence | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Check1, Check2,  }
        let mut state = State::Check1;
        loop {
            match state {
                State::Check1 => {
                    if self.eof() {
                        eprintln!("TRACE: L118 maybe_fence:check1 EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L119 maybe_fence:check1.tick2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Check2;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L120 maybe_fence:check1.not_fence | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::Check2 => {
                    if self.eof() {
                        eprintln!("TRACE: L122 maybe_fence:check2 EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L123 maybe_fence:check2.tick3 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_code_block(on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L124 maybe_fence:check2.not_fence | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse code_block -> CodeBlock
    fn parse_code_block<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L126 ENTER code_block | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::CodeBlockStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Info, Content, End1, End2, End3,  }
        let mut state = State::Info;
        loop {
            match state {
                State::Info => {
                    match self.scan_to1(b'\n') {
                        Some(b'\n') => {
                            eprintln!("TRACE: L129 code_block:info.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        None => {
                            eprintln!("TRACE: L128 code_block:info EOF | term={} pos={}", self.trace_content(), self.pos);
                            on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                            return;
                        }
                        _ => unreachable!("scan_to only returns target chars"),
                    }
                }
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L132 code_block:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L133 code_block:content.maybe_end | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::End1;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L134 code_block:content.newline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L135 code_block:content.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_code_line(on_event);
                    continue;
                        }
                    }
                }
                State::End1 => {
                    if self.eof() {
                        eprintln!("TRACE: L137 code_block:end1 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L138 code_block:end1.tick2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::End2;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L139 code_block:end1.newline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L140 code_block:end1.not_end | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_code_line(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::End2 => {
                    if self.eof() {
                        eprintln!("TRACE: L142 code_block:end2 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L143 code_block:end2.tick3 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::End3;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L144 code_block:end2.newline | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L145 code_block:end2.not_end | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_code_line(on_event);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::End3 => {
                    if self.eof() {
                        eprintln!("TRACE: L147 code_block:end3 EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::UnclosedCodeBlock, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L148 code_block:end3.extra | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L149 code_block:end3.done | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::CodeBlockEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L150 code_block:end3.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L151 code_block:end3.not_end | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse code_line -> Code
    fn parse_code_line<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L154 ENTER code_line | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to1(b'\n') {
                Some(b'\n') => {
                    eprintln!("TRACE: L156 code_line:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    eprintln!("TRACE: L155 code_line:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    on_event(Event::Error { code: ParseErrorCode::UnclosedCode, span: self.span() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse blockquote -> Blockquote
    fn parse_blockquote<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L163 ENTER blockquote | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::BlockquoteStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Start, Content, After, Next, Lazy,  }
        let mut state = State::Start;
        loop {
            match state {
                State::Start => {
                    if self.eof() {
                        eprintln!("TRACE: L164 blockquote:start EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ') => {
                            eprintln!("TRACE: L165 blockquote:start.space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Content;
                    continue;
                        }
                        Some(b'>') => {
                            eprintln!("TRACE: L166 blockquote:start.nested | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_blockquote(on_event);
                    state = State::After;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L167 blockquote:start.empty | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L168 blockquote:start.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Content;
                    continue;
                        }
                    }
                }
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L170 blockquote:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L171 blockquote:content.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L172 blockquote:content.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_inline(on_event);
                    continue;
                        }
                    }
                }
                State::After => {
                    if self.eof() {
                        eprintln!("TRACE: L174 blockquote:after EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L175 blockquote:after.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L176 blockquote:after.more | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_inline(on_event);
                    state = State::After;
                    continue;
                        }
                    }
                }
                State::Next => {
                    if self.eof() {
                        eprintln!("TRACE: L179 blockquote:next EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'>') => {
                            eprintln!("TRACE: L180 blockquote:next.cont | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Start;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L181 blockquote:next.blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BlockquoteEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L182 blockquote:next.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Lazy;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L183 blockquote:next.end | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BlockquoteEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::Lazy => {
                    if self.eof() {
                        eprintln!("TRACE: L186 blockquote:lazy EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::BlockquoteEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'>') => {
                            eprintln!("TRACE: L187 blockquote:lazy.quote | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Start;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L188 blockquote:lazy.blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::BlockquoteEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L189 blockquote:lazy.cont | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse dash_line
    fn parse_dash_line<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L195 ENTER dash_line | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { First, Second, HrCheck,  }
        let mut state = State::First;
        loop {
            match state {
                State::First => {
                    if self.eof() {
                        eprintln!("TRACE: L196 dash_line:first EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'-') => {
                            eprintln!("TRACE: L197 dash_line:first.dash2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Second;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L198 dash_line:first.space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L199 dash_line:first.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L200 dash_line:first.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::Second => {
                    if self.eof() {
                        eprintln!("TRACE: L202 dash_line:second EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'-') => {
                            eprintln!("TRACE: L203 dash_line:second.dash3 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::HrCheck;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L204 dash_line:second.space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L205 dash_line:second.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::HrCheck => {
                    if self.eof() {
                        eprintln!("TRACE: L207 dash_line:hr_check EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'-') => {
                            eprintln!("TRACE: L208 dash_line:hr_check.more | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L209 dash_line:hr_check.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L210 dash_line:hr_check.hr | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_thematic_break(on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L211 dash_line:hr_check.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse star_line
    fn parse_star_line<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L215 ENTER star_line | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { First, Second, HrCheck,  }
        let mut state = State::First;
        loop {
            match state {
                State::First => {
                    if self.eof() {
                        eprintln!("TRACE: L216 star_line:first EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                            eprintln!("TRACE: L217 star_line:first.star2 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Second;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L218 star_line:first.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::Second => {
                    if self.eof() {
                        eprintln!("TRACE: L220 star_line:second EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                            eprintln!("TRACE: L221 star_line:second.star3 | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::HrCheck;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L222 star_line:second.space | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L223 star_line:second.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_list_item(0, on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L224 star_line:second.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.prepend_bytes(b"*");
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
                State::HrCheck => {
                    if self.eof() {
                        eprintln!("TRACE: L226 star_line:hr_check EOF | term={} pos={}", self.trace_content(), self.pos);
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                            eprintln!("TRACE: L227 star_line:hr_check.more | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L228 star_line:hr_check.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L229 star_line:hr_check.hr | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_thematic_break(on_event);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L230 star_line:hr_check.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.prepend_bytes(b"**");
                    self.parse_paragraph(on_event);
                    return;
                        }
                    }
                }
            }
        }
    }

    /// Parse thematic_break -> ThematicBreak
    fn parse_thematic_break<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L233 ENTER thematic_break | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::ThematicBreakStart { span: start_span.clone() });
        loop {
            if self.eof() {
                eprintln!("TRACE: L234 thematic_break:main EOF | term={} pos={}", self.trace_content(), self.pos);
                on_event(Event::ThematicBreakEnd { span: self.span() });
                return;
            }
                    eprintln!("TRACE: L235 thematic_break:main.done | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ThematicBreakEnd { span: self.span() });
                    return;
        }
    }

    /// Parse list_item -> ListItem
    fn parse_list_item<F>(&mut self, col: i32, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L241 ENTER list_item | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::ListItemStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, Next, AfterBlank, CheckIndent,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L242 list_item:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L243 list_item:content.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::Next;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L244 list_item:content.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_inline(on_event);
                    continue;
                        }
                    }
                }
                State::Next => {
                    if self.eof() {
                        eprintln!("TRACE: L247 list_item:next EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L248 list_item:next.blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterBlank;
                    continue;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L249 list_item:next.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckIndent;
                    continue;
                        }
                        Some(b'-') => {
                            eprintln!("TRACE: L250 list_item:next.sibling | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        Some(b'*') => {
                            eprintln!("TRACE: L251 list_item:next.sibling | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L252 list_item:next.dedent | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::AfterBlank => {
                    if self.eof() {
                        eprintln!("TRACE: L255 list_item:after_blank EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'\n') => {
                            eprintln!("TRACE: L256 list_item:after_blank.more_blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L257 list_item:after_blank.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::CheckIndent;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L258 list_item:after_blank.end | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::CheckIndent => {
                    if self.eof() {
                        eprintln!("TRACE: L261 list_item:check_indent EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::ListItemEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t') => {
                            eprintln!("TRACE: L262 list_item:check_indent.ws | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    continue;
                        }
                        _ if self.col() <= col => {
                            eprintln!("TRACE: L263 list_item:check_indent | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::ListItemEnd { span: self.span() });
                    return;
                        }
                        Some(b'-') => {
                            eprintln!("TRACE: L264 list_item:check_indent.nested | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_list_item(self.col(), on_event);
                    state = State::Next;
                    continue;
                        }
                        Some(b'*') => {
                            eprintln!("TRACE: L265 list_item:check_indent.nested | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_list_item(self.col(), on_event);
                    state = State::Next;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L266 list_item:check_indent.blank | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterBlank;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L267 list_item:check_indent.cont | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::Content;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse inline
    fn parse_inline<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L278 ENTER inline | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        #[derive(Clone, Copy)]
        enum State { Main, AfterStar, AfterTwoStars, AfterUnder, AfterTwoUnders, AfterTilde, AfterTwoTildes,  }
        let mut state = State::Main;
        loop {
            match state {
                State::Main => {
                    if self.eof() {
                        eprintln!("TRACE: L279 inline:main EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L280 inline:main.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'*') => {
                            eprintln!("TRACE: L281 inline:main.star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterStar;
                    continue;
                        }
                        Some(b'_') => {
                            eprintln!("TRACE: L282 inline:main.under | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterUnder;
                    continue;
                        }
                        Some(b'~') => {
                            eprintln!("TRACE: L283 inline:main.tilde | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterTilde;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L284 inline:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L285 inline:main.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_text(on_event);
                    continue;
                        }
                    }
                }
                State::AfterStar => {
                    if self.eof() {
                        eprintln!("TRACE: L288 inline:after_star EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                            eprintln!("TRACE: L289 inline:after_star.double | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterTwoStars;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L290 inline:after_star.not_left | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L291 inline:after_star.emph | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_emphasis(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTwoStars => {
                    if self.eof() {
                        eprintln!("TRACE: L294 inline:after_two_stars EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L295 inline:after_two_stars.not_left | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"**"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L296 inline:after_two_stars.strong | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_strong(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterUnder => {
                    if self.eof() {
                        eprintln!("TRACE: L299 inline:after_under EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'_') => {
                            eprintln!("TRACE: L300 inline:after_under.double | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterTwoUnders;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L301 inline:after_under.not_left | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"_"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L302 inline:after_under.emph | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_emphasis_under(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTwoUnders => {
                    if self.eof() {
                        eprintln!("TRACE: L305 inline:after_two_unders EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L306 inline:after_two_unders.not_left | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"__"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L307 inline:after_two_unders.strong | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_strong_under(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTilde => {
                    if self.eof() {
                        eprintln!("TRACE: L310 inline:after_tilde EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'~') => {
                            eprintln!("TRACE: L311 inline:after_tilde.double | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::AfterTwoTildes;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L312 inline:after_tilde.literal | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                    }
                }
                State::AfterTwoTildes => {
                    if self.eof() {
                        eprintln!("TRACE: L315 inline:after_two_tildes EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::Error { code: ParseErrorCode::Unclosed, span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L316 inline:after_two_tildes.not_left | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"~~"), span: self.span() });
                    state = State::Main;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L317 inline:after_two_tildes.strike | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_strikethrough(on_event);
                    state = State::Main;
                    continue;
                        }
                    }
                }
            }
        }
    }

    /// Parse code_span -> Code
    fn parse_code_span<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L322 ENTER code_span | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        self.mark();
        loop {
            match self.scan_to2(b'`', b'\n') {
                Some(b'`') => {
                    eprintln!("TRACE: L324 code_span:main.end | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.set_term(0);
                    self.advance();
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                Some(b'\n') => {
                    eprintln!("TRACE: L325 code_span:main.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                None => {
                    eprintln!("TRACE: L323 code_span:main EOF | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::Code { content: self.term(), span: self.span_from_mark() });
                    return;
                }
                _ => unreachable!("scan_to only returns target chars"),
            }
        }
    }

    /// Parse emphasis -> Emphasis
    fn parse_emphasis<F>(&mut self, on_event: &mut F)
    where
        F: FnMut(Event<'a>),
    {
        eprintln!("TRACE: L336 ENTER emphasis | byte={} pos={}", Self::trace_byte(self.peek()), self.pos);
        let start_span = self.span();
        on_event(Event::EmphasisStart { span: start_span.clone() });
        #[derive(Clone, Copy)]
        enum State { Content, CheckStar, RightFlankDouble, NotRightFlanking, NotRfDouble,  }
        let mut state = State::Content;
        loop {
            match state {
                State::Content => {
                    if self.eof() {
                        eprintln!("TRACE: L337 emphasis:content EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'`') => {
                            eprintln!("TRACE: L338 emphasis:content.code | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    self.parse_code_span(on_event);
                    continue;
                        }
                        Some(b'*') => {
                            eprintln!("TRACE: L339 emphasis:content.star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    state = State::CheckStar;
                    continue;
                        }
                        Some(b'\n') => {
                            eprintln!("TRACE: L340 emphasis:content.eol | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                        }
                        _ => {
                            eprintln!("TRACE: L341 emphasis:content.text | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.parse_emph_text(on_event);
                    continue;
                        }
                    }
                }
                State::CheckStar => {
                    if self.eof() {
                        eprintln!("TRACE: L344 emphasis:check_star EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        _ if self.prev() == b' ' => {
                            eprintln!("TRACE: L345 emphasis:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\t' => {
                            eprintln!("TRACE: L346 emphasis:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == b'\n' => {
                            eprintln!("TRACE: L347 emphasis:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        _ if self.prev() == 0 => {
                            eprintln!("TRACE: L348 emphasis:check_star | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRightFlanking;
                    continue;
                        }
                        Some(b'*') => {
                            eprintln!("TRACE: L350 emphasis:check_star.double | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L351 emphasis:check_star.close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                        }
                    }
                }
                State::RightFlankDouble => {
                    eprintln!("TRACE: L356 emphasis:right_flank_double.close UNCONDITIONAL | term={} pos={}", self.trace_content(), self.pos);
                    on_event(Event::EmphasisEnd { span: self.span() });
                    return;
                }
                State::NotRightFlanking => {
                    if self.eof() {
                        eprintln!("TRACE: L359 emphasis:not_right_flanking EOF | term={} pos={}", self.trace_content(), self.pos);
                        on_event(Event::EmphasisEnd { span: self.span() });
                        return;
                    }
                    match self.peek() {
                        Some(b'*') => {
                            eprintln!("TRACE: L360 emphasis:not_right_flanking.double | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
                    state = State::NotRfDouble;
                    continue;
                        }
                        Some(b' ' | b'\t' | b'\n') => {
                            eprintln!("TRACE: L361 emphasis:not_right_flanking.literal | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    on_event(Event::Text { content: std::borrow::Cow::Borrowed(b"*"), span: self.span() });
                    state = State::Content;
