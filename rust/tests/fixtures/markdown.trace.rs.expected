                    self.advance();
                    state = State::RightFlankDouble;
                    continue;
                        }
                        _ => {
                            eprintln!("TRACE: L427 emphasis_under:check_under.close | byte={} term={} pos={}", Self::trace_byte(self.peek()), self.trace_content(), self.pos);
                    self.advance();
